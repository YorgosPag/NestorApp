# 🏢 ENTERPRISE PACKAGE MANAGEMENT CONFIGURATION
# This file enforces pnpm usage and enterprise-level dependency management

# ========================================================
# 🔒 PNPM ENFORCEMENT - Block npm/yarn usage
# ========================================================
engine-strict=true

# 🚫 Disable npm completely - Force pnpm usage
disable-npm=true

# 📦 Use pnpm workspace protocol for internal dependencies
link-workspace-packages=true
prefer-workspace-packages=true

# ========================================================
# 🏢 ENTERPRISE SECURITY & INTEGRITY
# ========================================================

# 🔐 Package verification for supply chain security
verify-signatures=true
audit-level=moderate

# 🏗️ Lock file integrity enforcement
package-lock-only=false
prefer-frozen-lockfile=true

# 🔍 Enhanced security scanning
audit=true

# ========================================================
# 🚀 ENTERPRISE PERFORMANCE OPTIMIZATION
# ========================================================

# 💾 Store configuration for better performance
store-dir=~/.pnpm-store
state-dir=~/.pnpm-state

# ⚡ Parallel installation for faster builds
child-concurrency=4
network-concurrency=8

# 🎯 Efficient dependency resolution
resolution-mode=highest
hoist=true
hoist-pattern[]=*

# 🏢 ENTERPRISE: pdfjs-dist browser hoist (required for react-pdf/Next.js)
# Fixes ESM/Webpack compatibility issues with pdf.js
public-hoist-pattern[]=pdfjs-dist

# ========================================================
# 📊 ENTERPRISE LOGGING & MONITORING
# ========================================================

# 📋 Detailed logging for enterprise monitoring
loglevel=info
progress=true

# 🏗️ Build reporting for CI/CD integration
reporter=default

# ========================================================
# 🌐 REGISTRY & MIRROR CONFIGURATION
# ========================================================

# 📍 Default npm registry (can be overridden for enterprise registries)
registry=https://registry.npmjs.org/

# 🔄 Retry configuration for enterprise networks
fetch-retries=3
fetch-retry-factor=2
fetch-retry-maxtimeout=120000
fetch-timeout=300000

# ========================================================
# 🏢 WORKSPACE & MONOREPO CONFIGURATION
# ========================================================

# 🔗 Enable workspace features
workspace-root=true
shared-workspace-lockfile=true

# 📦 Automatic workspace dependency linking
auto-install-peers=true
dedupe-peer-dependents=true

# ========================================================
# 🚨 ENTERPRISE STRICT MODE
# ========================================================

# ⚠️ Peer dependency checking — false to prevent Vercel build failures from unmet peer deps
strict-peer-dependencies=false

# 🔒 Block legacy npm behavior
save-exact=true
save-prefix=""

# 📋 Enterprise-level dependency validation
node-linker=isolated
symlink=true