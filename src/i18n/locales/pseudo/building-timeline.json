        },
        "tooltips": {
          "overallProgress": "[[~~~~~~~~~~~~ Το σταθμισμένο ποσοστό ολοκλήρωσης όλων των φάσεων κατασκευής.\nΥπολογισμός: Σ(πρόοδος φάσης × βάρος φάσης) / Σ(βάρη).\nΣυγκρίνεται με την αναμενόμενη πρόοδο βάσει χρόνου που έχει παρέλθει. ~~~~~~~~~~~~]]",
          "spi": "[[~~~~~~~~~~~~ Schedule Performance Index — μετρά την αποδοτικότητα χρονοδιαγράμματος.\nΤύπος: SPI = EV / PV (Δεδουλευμένη Αξία ÷ Προγραμματισμένη Αξία).\n• SPI = 1.0 → Εντός χρονοδιαγράμματος\n• SPI > 1.0 → Μπροστά από το πρόγραμμα\n• SPI < 1.0 → Πίσω από το πρόγραμμα\nΠρότυπο PMBOK (PMI). Φανάρι: Πράσινο ≥ 0.95, Πορτοκαλί ≥ 0.85, Κόκκινο < 0.85. ~~~~~~~~~~~~]]",
          "cpi": "[[~~~~~~~~~~~~ Cost Performance Index — μετρά την κοστολογική αποδοτικότητα.\nΤύπος: CPI = EV / AC (Δεδουλευμένη Αξία ÷ Πραγματικό Κόστος).\n• CPI = 1.0 → Εντός προϋπολογισμού\n• CPI > 1.0 → Κάτω από τον προϋπολογισμό\n• CPI < 1.0 → Πάνω από τον προϋπολογισμό\nΠρότυπο PMBOK (PMI). Φανάρι: Πράσινο ≥ 0.95, Πορτοκαλί ≥ 0.85, Κόκκινο < 0.85. ~~~~~~~~~~~~]]",
          "daysRemaining": "[[~~~~~~~~~~~~ Ημερολογιακές ημέρες μέχρι την τελευταία προγραμματισμένη λήξη φάσης.\nΥπολογισμός: max(ημ. λήξης φάσεων) − σήμερα.\nΦανάρι: Πράσινο = 0 (ολοκλήρωση), Πορτοκαλί ≤ 7 ημέρες, Γκρι > 7 ημέρες. ~~~~~~~~~~~~]]",
          "phasesOnTrack": "[[~~~~~~~~~~~~ Αριθμός φάσεων κατασκευής με κατάσταση 'Σε εξέλιξη' ή 'Ολοκληρωμένη' χωρίς καθυστέρηση.\nΦανάρι: Πράσινο > 80%, Πορτοκαλί ≥ 50%, Κόκκινο < 50%. ~~~~~~~~~~~~]]",
          "delayedTasks": "[[~~~~~~~~~~~~ Πλήθος εργασιών με κατάσταση 'Καθυστερημένη' επί του συνόλου.\nΦανάρι: Πράσινο = 0, Πορτοκαλί ≤ 3, Κόκκινο > 3. ~~~~~~~~~~~~]]",
          "criticalPathLength": "[[~~~~~~~~~~~~ Η συνολική διάρκεια (σε ημέρες) του μακρύτερου μονοπατιού στο δίκτυο εργασιών.\nΗ κρίσιμη διαδρομή καθορίζει την ελάχιστη διάρκεια του έργου.\nΟποιαδήποτε καθυστέρηση σε κρίσιμη εργασία καθυστερεί ολόκληρο το έργο. ~~~~~~~~~~~~]]",
          "sCurveTitle": "[[~~~~~~~~~~~~ S-Curve (Earned Value Management) — δείχνει σωρευτικό κόστος/πρόοδο στον χρόνο.\nΤο σχήμα 'S' είναι τυπικό: αργή εκκίνηση, ταχεία μέση φάση, αργό τέλος.\nΧρησιμοποιείται για πρώιμο εντοπισμό αποκλίσεων χρονοδιαγράμματος και κόστους. ~~~~~~~~~~~~]]",
          "pv": "[[~~~~~~~~~~~~ Planned Value (PV) — Προγραμματισμένη Αξία: το προϋπολογισμένο κόστος των εργασιών που έπρεπε να ολοκληρωθούν.\nΓνωστό και ως BCWS (Budgeted Cost of Work Scheduled).\nΑντιπροσωπεύει τη βάση αναφοράς: πόση δουλειά θα έπρεπε να έχει γίνει μέχρι τώρα. ~~~~~~~~~~~~]]",
          "ev": "[[~~~~~~~~~~~~ Earned Value (EV) — Δεδουλευμένη Αξία: το προϋπολογισμένο κόστος των εργασιών που πραγματικά εκτελέστηκαν.\nΓνωστό και ως BCWP (Budgeted Cost of Work Performed).\nΜετρά την πραγματική πρόοδο σε χρηματικούς όρους. ~~~~~~~~~~~~]]",
          "ac": "[[~~~~~~~~~~~~ Actual Cost (AC) — Πραγματικό Κόστος: το συνολικό κόστος που πραγματικά δαπανήθηκε.\nΓνωστό και ως ACWP (Actual Cost of Work Performed).\nΑντιπροσωπεύει την πραγματική δαπάνη για τις ολοκληρωμένες εργασίες. ~~~~~~~~~~~~]]",
          "sv": "[[~~~~~~~~~~~~ Schedule Variance (SV) — Απόκλιση Χρονοδιαγράμματος = EV − PV.\n• SV > 0 → Μπροστά από το πρόγραμμα\n• SV = 0 → Εντός χρονοδιαγράμματος\n• SV < 0 → Πίσω από το πρόγραμμα ~~~~~~~~~~~~]]",
          "svShort": "[[~~~~~ (Schedule Variance = EV − PV) ~~~~~]]",
          "cv": "[[~~~~~~~~~~~~ Cost Variance (CV) — Κοστολογική Απόκλιση = EV − AC.\n• CV > 0 → Κάτω από τον προϋπολογισμό\n• CV = 0 → Εντός προϋπολογισμού\n• CV < 0 → Πάνω από τον προϋπολογισμό ~~~~~~~~~~~~]]",
          "cvShort": "[[~~~~ (Cost Variance = EV − AC) ~~~~]]",
          "pvShort": "[[~~~~ (Planned Value — BCWS) ~~~~]]",
          "evShort": "[[~~~~ (Earned Value — BCWP) ~~~~]]",
          "acShort": "[[~~~~ (Actual Cost — ACWP) ~~~~]]",
          "criticalPathTitle": "[[~~~~~~~~~~~~ Critical Path Method (CPM) — εντοπίζει τη μακρύτερη ακολουθία εξαρτώμενων εργασιών.\nΟι εργασίες στην κρίσιμη διαδρομή έχουν μηδενικό float: κάθε καθυστέρηση μεταφέρεται στο τέλος του έργου.\nΟι μη-κρίσιμες εργασίες έχουν float (χαλαρότητα) που επιτρέπει κάποια καθυστέρηση χωρίς επίπτωση. ~~~~~~~~~~~~]]",
          "es": "[[~~~~~~~~~~~~ Early Start (ES) — Πρώιμη Έναρξη: η νωρίτερη δυνατή ημερομηνία έναρξης μιας εργασίας.\nΚαθορίζεται από το Forward Pass του αλγορίθμου CPM.\nΕξαρτάται από τις ημερομηνίες ολοκλήρωσης των προηγούμενων εργασιών. ~~~~~~~~~~~~]]",
          "ef": "[[~~~~~~~~~~~~ Early Finish (EF) — Πρώιμη Λήξη: η νωρίτερη δυνατή ημερομηνία ολοκλήρωσης μιας εργασίας.\nΤύπος: EF = ES + Διάρκεια.\nΚαθορίζεται κατά το Forward Pass του CPM. ~~~~~~~~~~~~]]",
          "ls": "[[~~~~~~~~~~~~ Late Start (LS) — Καθυστερημένη Έναρξη: η αργότερη ημερομηνία που μπορεί να ξεκινήσει μια εργασία χωρίς να καθυστερήσει το έργο.\nΚαθορίζεται από το Backward Pass του αλγορίθμου CPM.\nΤύπος: LS = LF − Διάρκεια. ~~~~~~~~~~~~]]",
          "lf": "[[~~~~~~~~~~~~ Late Finish (LF) — Καθυστερημένη Λήξη: η αργότερη ημερομηνία ολοκλήρωσης χωρίς καθυστέρηση στο έργο.\nΚαθορίζεται κατά το Backward Pass του CPM.\nΕξαρτάται από τις απαιτήσεις των επόμενων εργασιών. ~~~~~~~~~~~~]]",
          "float": "[[~~~~~~~~~~~~ Total Float (Χαλαρότητα) — ο μέγιστος χρόνος που μπορεί να καθυστερήσει μια εργασία χωρίς να καθυστερήσει το έργο.\nΤύπος: Float = LS − ES = LF − EF.\n• Float = 0 → Κρίσιμη εργασία (στην κρίσιμη διαδρομή)\n• Float > 0 → Μη-κρίσιμη (έχει ευελιξία χρονοπρογραμματισμού) ~~~~~~~~~~~~]]",
          "duration": "[[~~~~~~~~~~~~ Διάρκεια εργασίας σε εργάσιμες ημέρες.\nΟ χρόνος που απαιτείται για την ολοκλήρωση της εργασίας από την αρχή ως το τέλος. ~~~~~~~~~~~~]]",
          "varianceTitle": "[[~~~~~~~~~~~~ Ανάλυση Απόκλισης Χρονοδιαγράμματος — σύγκριση προγραμματισμένων vs πραγματικών ημερομηνιών ανά φάση/εργασία.\nΘετική απόκλιση = καθυστέρηση (ημέρες πίσω από το πρόγραμμα).\nΑρνητική απόκλιση = μπροστά από το πρόγραμμα. ~~~~~~~~~~~~]]",
          "lookaheadTitle": "[[~~~~~~~~~~~~ Πρόβλεψη — οι εργασίες εντός του επιλεγμένου χρονικού παραθύρου (2 ή 4 εβδομάδες).\nΧρησιμοποιείται στις εβδομαδιαίες συναντήσεις συντονισμού για προγραμματισμό. ~~~~~~~~~~~~]]",
          "baselineTitle": "[[~~~~~~~~~~~~ Στιγμιότυπα Βάσης — αποθηκευμένα αντίγραφα του χρονοδιαγράμματος σε συγκεκριμένες χρονικές στιγμές.\nΧρησιμοποιούνται για παρακολούθηση ολίσθησης: σύγκριση τρέχουσας κατάστασης με αρχικό πλάνο.\nΣτάνταρ: αποθήκευση βάσης πριν την κατασκευή, μετά από σημαντικές αλλαγές. ~~~~~~~~~~~~]]",
          "delayBreakdownTitle": "[[~~~~~~~~~~~~ Ανάλυση Καθυστερήσεων — κατηγοριοποίηση καθυστερημένων/μπλοκαρισμένων εργασιών ανά αιτία.\nΒοηθά στον εντοπισμό συστημικών προβλημάτων (π.χ. επαναλαμβανόμενες καθυστερήσεις αδειών, ελλείψεις υλικών). ~~~~~~~~~~~~]]",
          "resourceHistogramTitle": "[[~~~~~~~~~~~~ Ιστόγραμμα Πόρων — δείχνει τις ώρες ανά πόρο ανά εβδομάδα.\nΗ γραμμή χωρητικότητας 40ω δείχνει πλήρη απασχόληση.\nΡάβδοι πάνω από τη χωρητικότητα σημαίνουν υπερ-κατανομή. ~~~~~~~~~~~~]]",
          "resourceUtilizationTitle": "[[~~~~~~~~~~~~ Δείκτες Αξιοποίησης Πόρων — σύνοψη αποδοτικότητας κατανομής πόρων.\nΜ.Ο. Αξιοποίησης = μέσες ώρες ανάθεσης / χωρητικότητα σε όλους τους πόρους.\nΥπερ-Κατανεμημένοι = πόροι που ξεπερνούν τη χωρητικότητα 40ω/εβδομάδα. ~~~~~~~~~~~~]]"
        }
      },
