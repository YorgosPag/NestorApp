        "tooltips": {
          "overallProgress": "The weighted completion percentage of all construction phases.\nCalculated as: Σ(phase progress × phase weight) / Σ(weights).\nCompared against the expected progress based on elapsed time.",
          "spi": "Schedule Performance Index — measures schedule efficiency.\nFormula: SPI = EV / PV (Earned Value ÷ Planned Value).\n• SPI = 1.0 → On schedule\n• SPI > 1.0 → Ahead of schedule\n• SPI < 1.0 → Behind schedule\nPMBOK standard (PMI). Traffic light: Green ≥ 0.95, Amber ≥ 0.85, Red < 0.85.",
          "cpi": "Cost Performance Index — measures cost efficiency.\nFormula: CPI = EV / AC (Earned Value ÷ Actual Cost).\n• CPI = 1.0 → On budget\n• CPI > 1.0 → Under budget\n• CPI < 1.0 → Over budget\nPMBOK standard (PMI). Traffic light: Green ≥ 0.95, Amber ≥ 0.85, Red < 0.85.",
          "daysRemaining": "Calendar days until the latest planned phase end date.\nCalculated as: max(phase planned end dates) − today.\nTraffic light: Green = 0 (complete), Amber ≤ 7 days, Gray > 7 days.",
          "phasesOnTrack": "Number of construction phases with status 'In Progress' or 'Completed' without delay.\nTraffic light: Green > 80%, Amber ≥ 50%, Red < 50%.",
          "delayedTasks": "Count of tasks with status 'Delayed' out of total tasks.\nTraffic light: Green = 0, Amber ≤ 3, Red > 3.",
          "criticalPathLength": "Total duration (in days) of the longest path through the project network.\nThe critical path determines the minimum project duration.\nAny delay in a critical task delays the entire project.",
          "sCurveTitle": "S-Curve (Earned Value Management) — shows cumulative cost/progress over time.\nThe 'S' shape is typical: slow start, rapid middle, slow finish.\nUsed for early detection of schedule and cost deviations.",
          "pv": "Planned Value (PV) — the budgeted cost of work scheduled.\nAlso known as BCWS (Budgeted Cost of Work Scheduled).\nRepresents the baseline: how much work should have been done by now.",
          "ev": "Earned Value (EV) — the budgeted cost of work actually performed.\nAlso known as BCWP (Budgeted Cost of Work Performed).\nMeasures actual progress in monetary terms.",
          "ac": "Actual Cost (AC) — the total cost actually incurred.\nAlso known as ACWP (Actual Cost of Work Performed).\nRepresents real expenditure for work completed.",
          "sv": "Schedule Variance (SV) = EV − PV.\n• SV > 0 → Ahead of schedule\n• SV = 0 → On schedule\n• SV < 0 → Behind schedule",
          "svShort": "(Schedule Variance = EV − PV)",
          "cv": "Cost Variance (CV) = EV − AC.\n• CV > 0 → Under budget\n• CV = 0 → On budget\n• CV < 0 → Over budget",
          "cvShort": "(Cost Variance = EV − AC)",
          "pvShort": "(Planned Value — BCWS)",
          "evShort": "(Earned Value — BCWP)",
          "acShort": "(Actual Cost — ACWP)",
          "criticalPathTitle": "Critical Path Method (CPM) — identifies the longest sequence of dependent tasks.\nTasks on the critical path have zero float: any delay cascades to the project end date.\nNon-critical tasks have float (slack) that allows some delay without impact.",
          "es": "Early Start (ES) — the earliest possible date a task can begin.\nDetermined by the forward pass of the CPM algorithm.\nDepends on predecessor task completion dates.",
          "ef": "Early Finish (EF) — the earliest possible date a task can be completed.\nFormula: EF = ES + Duration.\nDetermined during the forward pass of CPM.",
          "ls": "Late Start (LS) — the latest date a task can begin without delaying the project.\nDetermined by the backward pass of the CPM algorithm.\nFormula: LS = LF − Duration.",
          "lf": "Late Finish (LF) — the latest date a task can finish without delaying the project.\nDetermined during the backward pass of CPM.\nDepends on successor task requirements.",
          "float": "Total Float (Slack) — the maximum time a task can be delayed without delaying the project.\nFormula: Float = LS − ES = LF − EF.\n• Float = 0 → Critical task (on critical path)\n• Float > 0 → Non-critical (has scheduling flexibility)",
          "duration": "Task duration in working days.\nThe time required to complete the task from start to finish.",
          "varianceTitle": "Schedule Variance Analysis — compares planned vs actual dates per phase/task.\nPositive variance = delay (days behind schedule).\nNegative variance = ahead of schedule.",
          "lookaheadTitle": "Lookahead Schedule — upcoming tasks within the selected time window (2 or 4 weeks).\nUsed in weekly coordination meetings to plan near-term work.",
          "baselineTitle": "Baseline Snapshots — saved copies of the schedule at specific points in time.\nUsed to track schedule drift: compare current dates against the original plan.\nIndustry standard: save baseline before construction start, after major changes.",
          "delayBreakdownTitle": "Delay Breakdown — categorizes delayed/blocked tasks by cause.\nHelps identify systemic issues (e.g., recurring permit delays, material shortages).",
          "resourceHistogramTitle": "Resource Histogram — shows allocated hours per resource per week.\nThe 40h capacity line indicates full-time utilization.\nBars exceeding capacity indicate over-allocation.",
          "resourceUtilizationTitle": "Resource Utilization KPIs — summary of resource allocation efficiency.\nAvg. Utilization = mean hours assigned / capacity across all resources.\nOver-Allocated = resources exceeding 40h/week capacity."
        }
      },
