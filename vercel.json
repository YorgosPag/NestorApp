{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "autoCancel": true
  },
  "ignoreCommand": "bash scripts/ignore-build.sh",
  "crons": [
    {
      "path": "/api/cron/email-ingestion",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/ai-learning",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/file-purge",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/overdue-alerts",
      "schedule": "0 0 * * *"
    }
  ]
}
