{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/middleware.ts",
    "src/**/*.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "-.next",
    "functions/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/__tests__/**",
    "src/subapps/dxf-viewer/**",
    "src/subapps/dxf-viewer/patches/**",
    "src/subapps/dxf-viewer/archive/**",
    "src/subapps/dxf-viewer-10-backup/**",
    "src/app/test.BACK/**",
    "src/subapps/dxf-viewer/test.BACK/**",
    "src/ai/**",
    "src/ai.back/**",
    "DxfViewerApp.tsx",
    "recovery/**",
    "migrate-*.ts"
  ]
}
