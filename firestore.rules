    // =========================================================================
    // 📝 AUDIT COLLECTIONS - SECURITY & COMPLIANCE
    // =========================================================================
    // 📅 Added: 2026-01-17 (Permission-denied fix - HIGH priority)
    // 🏢 ENTERPRISE: Audit logs are READ-ONLY for clients (write via Admin SDK)
    match /relationship_audit/{auditId} {
      allow read: if isAuthenticated();
      allow write: if false; // Server-side only
    }

    // =========================================================================
    // 📜 ENTITY_AUDIT_TRAIL - CANONICAL ENTITY CHANGE LOG (ADR-195 Phase 10)
    // =========================================================================
    // 📅 Added: 2026-04-11 (ADR-195 Phase 10 — Client-side onSnapshot SSoT)
    // 🏢 ENTERPRISE: Canonical source of truth for every entity mutation.
    //    Client hooks subscribe DIRECTLY via Firestore onSnapshot (no HTTP
    //    polling, no manual RealtimeService event lists). Firestore rules are
    //    the sole authorization layer.
    // 🔒 READ: Tenant-scoped + admin-only (super_admin | company_admin). No
    //    downgrade to plain authenticated reads — audit data is sensitive.
    // 🚫 WRITE: Server-only via Firebase Admin SDK (EntityAuditService).
    //    Admin SDK bypasses rules, so `allow write: if false` is safe.
    // 📎 SSoT: See `.ssot-registry.json` → `entity-audit-trail` module.
    //    Canonical reader: `src/services/entity-audit-client.service.ts`.
    match /entity_audit_trail/{auditId} {
      allow read: if isAuthenticated()
                  && (
                       // Super admin sees all audit entries (bypasses tenant check)
                       isSuperAdminOnly()
                       // OR company admin of the audit entry's company
                       || (resource.data.keys().hasAny(['companyId'])
                           && isCompanyAdminOfCompany(resource.data.companyId)
                           && belongsToCompany(resource.data.companyId))
                     );
      allow write: if false; // Server-side only (Admin SDK)
    }

    // =========================================================================
    // 🏢 ADMIN_BUILDING_TEMPLATES - ENTERPRISE TENANT ISOLATION (PR-1D)
    // =========================================================================
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1D)
    // 🏢 ENTERPRISE: Building templates with tenant isolation
    // =========================================================================
    match /admin_building_templates/{templateId} {
      // 📖 READ: Tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // LEGACY FALLBACK: Creator-only
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.keys().hasAny(['createdBy'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE: companyId required
      allow create: if isAuthenticated()
                    && request.resource.data.companyId == getUserCompanyId();

      // 📝 UPDATE: Creator or company admin, companyId immutable
      allow update: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       )
                    && (!resource.data.keys().hasAny(['companyId'])
                        || request.resource.data.companyId == resource.data.companyId);

      // 🗑️ DELETE: Creator or company admin
      allow delete: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       );
    }

    match /audit_logs/{logId} {
      allow read: if isAuthenticated();
      allow write: if false; // Server-side only
    }

    // =========================================================================
    // 📄 FILE_AUDIT_LOG - ENTERPRISE FILE AUDIT TRAIL (ADR-191 Phase 3.1)
    // =========================================================================
    // 📅 Added: 2026-03-09 (ADR-191 - Enterprise Document Management)
    // 📅 Updated: 2026-03-20 (ADR-255 SPEC-255A — Tenant Isolation)
    // 🏢 ENTERPRISE: Records every file operation for compliance traceability
    // 🔒 READ: Tenant-scoped (companyId match)
    // ✏️ CREATE: Tenant-scoped (companyId required)
    match /file_audit_log/{logId} {
      allow read: if isAuthenticated()
                  && belongsToCompany(resource.data.companyId);
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['companyId'])
                    && (isSuperAdminOnly() || request.resource.data.companyId == getUserCompanyId());
      allow update, delete: if false; // Audit logs are immutable
    }

    // =========================================================================
    // 🔗 FILE_SHARES - ENTERPRISE SHAREABLE LINKS (ADR-191 Phase 4.2)
    // =========================================================================
    // 📅 Added: 2026-03-09 (ADR-191 - Enterprise Document Management)
    // 📅 Updated: 2026-03-20 (ADR-252 FR-C2 — tenant isolation on write)
    // 🏢 ENTERPRISE: Shareable file links with expiration and password
    // 🔒 READ: Public (for share token validation on /shared/[token] page)
    // ✏️ WRITE: Tenant-scoped (companyId required)
    match /file_shares/{shareId} {
      // 📖 READ: Public (for share token validation on /shared/[token] page)
      // 🔒 SECURITY: Share links must remain publicly readable for anonymous access
      allow read: if true;
      // ✍️ CREATE: Authenticated users with companyId enforcement
      // 🔒 SECURITY (ADR-252 FR-C2): Was `isAuthenticated()` → now enforces companyId
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['companyId', 'createdBy'])
                    && (isSuperAdminOnly() || request.resource.data.companyId == getUserCompanyId());
      // 📝 UPDATE: Authenticated tenant member OR public download counter
      // SECURITY: Public can ONLY increment downloadCount and lastDownloadedAt
      allow update: if (isAuthenticated()
                        && (isSuperAdminOnly()
                            || belongsToCompany(resource.data.companyId)))
                    || (
                         // Public can only increment download counter
                         request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['downloadCount', 'lastDownloadedAt'])
                       );
      // 🗑️ DELETE: Creator only
      allow delete: if isAuthenticated()
                    && resource.data.createdBy == request.auth.uid;
    }

    // =========================================================================
    // 📸 PHOTO_SHARES — CRM Contact Channel Share History
    // =========================================================================
    // 📅 Added: 2026-04-09 — Photo Share History Feature
    match /photo_shares/{shareId} {
      // 📖 READ: Authenticated tenant members only
      allow read: if isAuthenticated()
                  && (isSuperAdminOnly()
                      || belongsToCompany(resource.data.companyId));
      // ✍️ CREATE: Authenticated with companyId + contactId enforcement
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['companyId', 'createdBy', 'contactId'])
                    && (isSuperAdminOnly() || request.resource.data.companyId == getUserCompanyId());
      // 📝 UPDATE: Immutable records — no updates
      allow update: if false;
      // 🗑️ DELETE: Super admin only
      allow delete: if isSuperAdminOnly();
    }

    // =========================================================================
    // 💬 FILE_COMMENTS - INLINE COMMENTS (ADR-191 Phase 4.3)
    // =========================================================================
    // 📅 Added: 2026-03-09 (ADR-191 - Enterprise Document Management)
    // 📅 Updated: 2026-03-20 (ADR-255 SPEC-255A — Tenant Isolation)
    // 🏢 ENTERPRISE: Threaded comments on file documents
    // 🔒 READ/WRITE: Tenant-scoped (companyId required)
    match /file_comments/{commentId} {
      allow read: if isAuthenticated()
                  && belongsToCompany(resource.data.companyId);
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['companyId'])
                    && (isSuperAdminOnly() || request.resource.data.companyId == getUserCompanyId());
      allow update: if isAuthenticated()
                    && belongsToCompany(resource.data.companyId)
                    && request.resource.data.authorId == resource.data.authorId; // Only author can edit
      allow delete: if isAuthenticated()
                    && belongsToCompany(resource.data.companyId)
                    && resource.data.authorId == request.auth.uid; // Only author can delete
    }

    // =========================================================================
    // ✅ FILE_APPROVALS - DOCUMENT APPROVAL WORKFLOWS (ADR-191 Phase 3.3)
    // =========================================================================
    // 📅 Added: 2026-03-09 (ADR-191 - Enterprise Document Management)
    // 🏢 ENTERPRISE: Multi-step approval chains for documents
    // 🔒 READ/WRITE: Authenticated users only
    match /file_approvals/{approvalId} {
      // 📖 READ: Tenant-scoped — only users from the approval's company
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                     );
      // ✍️ CREATE: Authenticated users with companyId matching their company
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAny(['companyId'])
                    && (isSuperAdminOnly() || request.resource.data.companyId == getUserCompanyId());
      // 📝 UPDATE: Authenticated users from the same company (approve/reject)
      allow update: if isAuthenticated()
                    && (
                         isSuperAdminOnly()
                         || (resource.data.keys().hasAny(['companyId'])
                             && belongsToCompany(resource.data.companyId))
                       );
      allow delete: if false; // Approvals are immutable records
    }

    // =========================================================================
    // 📦 DOCUMENT_TEMPLATES - REUSABLE TEMPLATES (ADR-191 Phase 4.1)
    // =========================================================================
    // 📅 Added: 2026-03-09 (ADR-191 - Enterprise Document Management)
    // 🏢 ENTERPRISE: Document templates with variable interpolation
    // 🔒 READ/WRITE: Authenticated users only
    match /document_templates/{templateId} {
      // 📖 READ: Tenant-scoped — only users from the template's company
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                     );
      // ✍️ CREATE: Authenticated users with companyId matching their company
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAny(['companyId'])
                    && (isSuperAdminOnly() || request.resource.data.companyId == getUserCompanyId());
      // 📝 UPDATE: Creator or same company member
      allow update: if isAuthenticated()
                    && (
                         isSuperAdminOnly()
                         || (resource.data.keys().hasAny(['companyId'])
                             && belongsToCompany(resource.data.companyId))
                       );
      // 🗑️ DELETE: Creator or same company member
      allow delete: if isAuthenticated()
                    && (
                         isSuperAdminOnly()
                         || (resource.data.keys().hasAny(['companyId'])
                             && belongsToCompany(resource.data.companyId))
                       );
    }

    // =========================================================================
    // 🔔 FILE_WEBHOOKS - WEBHOOK REGISTRATIONS (ADR-191 Phase 5.4)
    // =========================================================================
    // 📅 Added: 2026-03-09 (ADR-191 - Enterprise Document Management)
    // 🏢 ENTERPRISE: Webhook subscriptions for document events
    // 🔒 Server-side only (managed via API routes)
    match /file_webhooks/{webhookId} {
      allow read, write: if false; // Server-side only via Admin SDK
    }

    // =========================================================================
    // 📁 FILE_FOLDERS - VIRTUAL FOLDER STRUCTURE (ADR-191 Phase 4.4)
    // =========================================================================
    // 📅 Added: 2026-03-09 (ADR-191 - Enterprise Document Management)
    // 🏢 ENTERPRISE: Virtual folders for file organization
    // 🔒 READ/WRITE: Authenticated users only
    match /file_folders/{folderId} {
      // 📖 READ: Tenant-scoped — only users from the folder's company
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                     );
      // ✍️ CREATE: Authenticated users with companyId matching their company
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAny(['companyId'])
                    && (isSuperAdminOnly() || request.resource.data.companyId == getUserCompanyId());
      // 📝 UPDATE: Same company member
      allow update: if isAuthenticated()
                    && (
                         isSuperAdminOnly()
                         || (resource.data.keys().hasAny(['companyId'])
                             && belongsToCompany(resource.data.companyId))
                       );
      // 🗑️ DELETE: Same company member
      allow delete: if isAuthenticated()
                    && (
                         isSuperAdminOnly()
                         || (resource.data.keys().hasAny(['companyId'])
                             && belongsToCompany(resource.data.companyId))
                       );
    }

    match /system_audit_logs/{logId} {
      allow read: if isAuthenticated();
      allow write: if false; // Server-side only
    }

    // =========================================================================
    // 📋 AUDIT_LOG COLLECTION - CLOUD FUNCTIONS AUDIT TRAIL
    // =========================================================================
    // 📅 Added: 2026-01-20 (ADR-032 - Enterprise Trash System)
    // 🏢 ENTERPRISE: Audit log for file purge operations (written by Cloud Functions)
    // 🔒 READ: Only super_admin can read audit logs
    // 🚫 WRITE: Server-side only (via Firebase Admin SDK)
    match /audit_log/{logId} {
      allow read: if isSuperAdminOnly();
      allow write: if false; // Server-side only (Cloud Functions use Admin SDK)
    }

    // =========================================================================
    // 👥 TEAMS - ENTERPRISE TENANT ISOLATION (PR-1D)
    // =========================================================================
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1D)
    // 🏢 ENTERPRISE: Team management with tenant isolation
    // =========================================================================
    match /teams/{teamId} {
      // 📖 READ: Tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // LEGACY FALLBACK: Creator-only
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.keys().hasAny(['createdBy'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE: companyId required
      allow create: if isAuthenticated()
                    && request.resource.data.companyId == getUserCompanyId();

      // 📝 UPDATE: Creator or company admin, companyId immutable
      allow update: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       )
                    && (!resource.data.keys().hasAny(['companyId'])
                        || request.resource.data.companyId == resource.data.companyId);

      // 🗑️ DELETE: Creator or company admin
      allow delete: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       );
    }

    // =========================================================================
    // 💼 POSITIONS - ROLE/POSITION MANAGEMENT
    // =========================================================================
    // 📅 Added: 2026-01-17 (Final 2 collections fix)
    // 🏢 ENTERPRISE: Position management (fallback for COLLECTIONS.ROLES)
    match /positions/{positionId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin/server only
    }

    // =========================================================================
    // ⚙️ SYSTEM - DUPLICATE REMOVED (ADR-252 FR-M1)
    // =========================================================================
    // 📅 Removed: 2026-03-20 — Merged into single system/{docId} block above
    // 🔒 SECURITY: Duplicate blocks caused most-permissive-wins in Firestore
    // =========================================================================

    // =========================================================================
    // 🔍 SEARCH_DOCUMENTS COLLECTION - GLOBAL SEARCH INDEX (ADR-029)
    // =========================================================================
    // 🏢 ENTERPRISE: Denormalized search index with tenant isolation
    // 📅 Added: 2026-01-26 (Global Search v1)
    //
    // Architecture:
    //   - Documents indexed by Cloud Functions triggers
    //   - Tenant-scoped reads via tenantId field
    //   - Write-only for server (Admin SDK)
    // =========================================================================
    match /search_documents/{searchDocId} {

      // 📖 READ: Tenant-scoped - only users from the same company
      // 🔒 SECURITY: Search results filtered by tenantId
      allow read: if isAuthenticated()
                  && (
                       // Super admin can search all
                       isSuperAdminOnly()
                       // OR user belongs to the document's tenant
                       || belongsToCompany(resource.data.tenantId)
                     );

      // 🚫 WRITE: Server-side only (Cloud Functions / Admin SDK)
      // Search index is maintained by triggers, not client writes
      allow create, update, delete: if false;
    }

    // =========================================================================
    // 🎤 VOICE_COMMANDS COLLECTION - IN-APP AI PIPELINE (ADR-164)
    // =========================================================================
    // 🏢 ENTERPRISE: Voice commands submitted via in-app mic → AI pipeline
    // 🔒 SECURITY: User-scoped read only (userId == auth.uid)
    // 📅 Added: 2026-02-09
    //
    // Security Model:
    //   - READ: Only the user who created the command (userId match)
    //   - WRITE: Server-only via Admin SDK (API route creates/updates)
    // =========================================================================
    match /voice_commands/{commandId} {

      // 📖 READ: User can only read their own voice commands
      // 🔒 SECURITY: Prevents cross-user access to AI responses
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;

      // 🚫 WRITE: Server-side only (Admin SDK via /api/voice/command)
      // Voice command lifecycle managed by API route and pipeline dispatcher
      allow create, update, delete: if false;
    }

    // =========================================================================
    // 📏 BOQ_ITEMS COLLECTION — Quantity Surveying / Επιμετρήσεις (ADR-175)
    // =========================================================================
    // Bill of Quantities items per building.
    // CRUD from client-side SDK (useBOQItems hook).
    // Governance flow: draft → submitted → approved → certified → locked.
    // Cost fields computed at runtime (NEVER stored as totals).
    // 📅 Updated: 2026-03-20 (ADR-252 FR-H1 — tenant isolation)
    // =========================================================================
    match /boq_items/{itemId} {

      // 📖 READ: Tenant-scoped
      // 🔒 SECURITY (ADR-252 FR-H1): Was `isAuthenticated()` → now tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                     );

      // ✍️ CREATE: Authenticated user with required fields + tenant check
      // 🔒 SECURITY (ADR-252 FR-H1): companyId MUST match user's company claim
      allow create: if isAuthenticated()
                    && resource == null
                    && request.resource.data.keys().hasAll([
                         'companyId', 'projectId', 'buildingId',
                         'categoryCode', 'title', 'unit', 'status',
                         'estimatedQuantity', 'createdAt', 'updatedAt'
                       ])
                    && request.resource.data.companyId is string
                    && (isSuperAdminOnly() || request.resource.data.companyId == getUserCompanyId())
                    && request.resource.data.projectId is string
                    && request.resource.data.buildingId is string
                    && request.resource.data.categoryCode is string
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.status in [
                         'draft', 'submitted', 'approved', 'certified', 'locked'
                       ]
                    && request.resource.data.estimatedQuantity is number;

      // ✏️ UPDATE: Tenant-scoped (buildingId and projectId immutable)
      allow update: if isAuthenticated()
                    && (isSuperAdminOnly() || belongsToCompany(resource.data.companyId))
                    && request.resource.data.buildingId == resource.data.buildingId
                    && request.resource.data.projectId == resource.data.projectId
                    && request.resource.data.companyId == resource.data.companyId
                    && request.resource.data.status in [
                         'draft', 'submitted', 'approved', 'certified', 'locked'
                       ];

      // 🗑️ DELETE: Tenant-scoped (only draft/submitted items)
      allow delete: if isAuthenticated()
                    && (isSuperAdminOnly() || belongsToCompany(resource.data.companyId))
                    && resource.data.status in ['draft', 'submitted'];
    }

    // =========================================================================
    // 📏 BOQ_CATEGORIES COLLECTION — ΑΤΟΕ Custom Categories (ADR-175)
    // =========================================================================
    // Company-specific BOQ category overrides.
    // Fallback to static ATOE_MASTER_CATEGORIES when empty.
    // Client reads only; future admin UI may write.
    // =========================================================================
    match /boq_categories/{categoryId} {

      // 📖 READ: Tenant-scoped
      // 🔒 SECURITY (ADR-252 FR-H3): Was `isAuthenticated()` → now tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // LEGACY: categories without companyId (system defaults) readable by all auth users
                       || !resource.data.keys().hasAny(['companyId'])
                     );

      // 🚫 WRITE: Reserved for future admin UI
      allow create, update, delete: if false;
    }

    // =========================================================================
    // 📁 BROKERAGE_AGREEMENTS COLLECTION — Μεσιτικές Συμβάσεις (ADR-230)
    // =========================================================================
    // Tenant-scoped: companyId must match user's company claim
    // =========================================================================
    match /brokerage_agreements/{agreementId} {

      // 📖 READ: Tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // LEGACY: documents without companyId — creator only
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE: companyId must match user claim
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['projectId', 'agentContactId', 'createdBy', 'companyId'])
                    && (
                         isSuperAdminOnly()
                         || request.resource.data.companyId == getUserCompanyId()
                       );

      // 📝 UPDATE: Creator or company admin
      allow update: if isAuthenticated()
                    && resource != null
                    && (
                         resource.data.createdBy == request.auth.uid
                         || (resource.data.keys().hasAny(['companyId'])
                             && isCompanyAdminOfCompany(resource.data.companyId))
                         || isSuperAdminOnly()
                       );

      // 🗑️ DELETE: Creator or company admin
      allow delete: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isSuperAdminOnly()
                       );
    }

    // =========================================================================
    // 📁 COMMISSION_RECORDS COLLECTION — Εγγραφές Προμηθειών (ADR-230)
    // =========================================================================
    match /commission_records/{recordId} {

      // 📖 READ: Tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE: companyId must match user claim
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['projectId', 'agentContactId', 'createdBy', 'companyId'])
                    && (
                         isSuperAdminOnly()
                         || request.resource.data.companyId == getUserCompanyId()
                       );

      // 📝 UPDATE: Creator or company admin (payment status updates)
      allow update: if isAuthenticated()
                    && resource != null
                    && (
                         resource.data.createdBy == request.auth.uid
                         || (resource.data.keys().hasAny(['companyId'])
                             && isCompanyAdminOfCompany(resource.data.companyId))
                         || isSuperAdminOnly()
                       );

      // 🗑️ DELETE: Super admin only
      allow delete: if isAuthenticated() && isSuperAdminOnly();
    }

    // =========================================================================
    // 📊 OWNERSHIP_TABLES COLLECTION — ADR-235 (Πίνακας Χιλιοστών)
    // =========================================================================
    // 📅 Updated: 2026-03-20 (ADR-252 FR-H2 — tenant isolation)
    // 🔒 SECURITY: Tenant-scoped via companyId + legacy creator fallback
    // =========================================================================
    match /ownership_tables/{tableId} {
      // 📖 READ: Tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.keys().hasAny(['createdBy'])
                           && resource.data.createdBy == request.auth.uid)
                     );
      // ✍️ CREATE: companyId must match user claim
      allow create: if isAuthenticated()
                    && (isSuperAdminOnly() || request.resource.data.companyId == getUserCompanyId());
      // 📝 UPDATE: Tenant-scoped
      allow update: if isAuthenticated()
                    && (
                         isSuperAdminOnly()
                         || (resource.data.keys().hasAny(['companyId'])
                             && belongsToCompany(resource.data.companyId))
                         || (!resource.data.keys().hasAny(['companyId'])
                             && resource.data.keys().hasAny(['createdBy'])
                             && resource.data.createdBy == request.auth.uid)
                       );
      // 🗑️ DELETE: Super admin only
      allow delete: if isAuthenticated() && isSuperAdminOnly();
    }

    // Revisions subcollection — inherits parent tenant isolation
    match /ownership_tables/{tableId}/revisions/{revisionId} {
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || belongsToCompany(
                            get(/databases/$(database)/documents/ownership_tables/$(tableId)).data.companyId
                          )
                     );
      allow create: if isAuthenticated()
                    && (
                         isSuperAdminOnly()
                         || belongsToCompany(
                              get(/databases/$(database)/documents/ownership_tables/$(tableId)).data.companyId
                            )
                       );
    }

    // =========================================================================
    // 📒 ACCOUNTING MODULE — 19 COLLECTIONS (Q2-Q8, AUDIT-2026-03-29)
    // =========================================================================
    // 📅 Added: 2026-03-31 (Εργασία #17 B-7)
    // 🔒 Tenant isolation via companyId field (Q3 Google pattern A)
    // 🏢 RBAC: Q4 super_admin/company_admin/internal_user/external_user
    // =========================================================================

    // ── Pattern A: Standard CRUD (13 collections) ──────────────────────────

    match /accounting_journal_entries/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_invoices/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_bank_transactions/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_bank_accounts/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_fixed_assets/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_depreciation_records/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_expense_documents/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_import_batches/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_tax_installments/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_apy_certificates/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_custom_categories/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_matching_rules/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    match /accounting_efka_payments/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccounting();
      allow update: if canUpdateAccounting(resource.data.companyId, resource.data.createdBy);
      allow delete: if canDeleteAccounting(resource.data.companyId, resource.data.createdBy);
    }

    // ── Pattern B: Audit Log — IMMUTABLE (Q7 ΚΦΔ compliance) ───────────────

    match /accounting_audit_log/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccountingSystem()
                    && request.resource.data.userId is string
                    && request.resource.data.userId == request.auth.uid;
      // Q7: Accounting audit log is 100% IMMUTABLE — zero update/delete
      allow update: if false;
      allow delete: if false;
    }

    // ── Pattern C: Fiscal Periods — Q8 SAP pattern ─────────────────────────

    match /accounting_fiscal_periods/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if isCompanyAdminOfCompany(request.resource.data.companyId)
                    && request.resource.data.companyId == getUserCompanyId();
      allow update: if isInternalUserOfCompany(resource.data.companyId)
                    && request.resource.data.companyId == resource.data.companyId
                    // Q8: lock/reopen → admin only; close (OPEN→CLOSED) → admin+internal
                    && (
                         // Status not changing → any internal user can update other fields
                         resource.data.status == request.resource.data.status
                         // OPEN → CLOSED: admin + internal_user
                         || (resource.data.status == 'OPEN' && request.resource.data.status == 'CLOSED')
                         // CLOSED → LOCKED or LOCKED → OPEN: admin only
                         || isCompanyAdminOfCompany(resource.data.companyId)
                       );
      // Fiscal periods are never deleted
      allow delete: if false;
    }

    // ── Pattern D: Settings Singletons — admin-only write ──────────────────

    match /accounting_settings/{docId} {
      allow read:   if isAuthenticated()
                    && (isSuperAdminOnly()
                        || (resource.data.keys().hasAny(['companyId'])
                            && isInternalUserOfCompany(resource.data.companyId)));
      allow create: if isCompanyAdmin()
                    && request.resource.data.companyId is string
                    && request.resource.data.companyId == getUserCompanyId();
      allow update: if resource.data.keys().hasAny(['companyId'])
                    && canWriteAccountingSingleton(resource.data.companyId)
                    && request.resource.data.companyId == resource.data.companyId;
      allow delete: if false;
    }

    match /accounting_efka_config/{docId} {
      allow read:   if isAuthenticated()
                    && (isSuperAdminOnly()
                        || (resource.data.keys().hasAny(['companyId'])
                            && isInternalUserOfCompany(resource.data.companyId)));
      allow create: if isCompanyAdmin()
                    && request.resource.data.companyId is string
                    && request.resource.data.companyId == getUserCompanyId();
      allow update: if resource.data.keys().hasAny(['companyId'])
                    && canWriteAccountingSingleton(resource.data.companyId)
                    && request.resource.data.companyId == resource.data.companyId;
      allow delete: if false;
    }

    // ── Pattern E: Server-only (Admin SDK) ─────────────────────────────────

    match /accounting_invoice_counters/{docId} {
      // Server-only via Admin SDK — no client access
      allow read, write: if false;
    }

    // ── Pattern F: Customer Balances — system-calculated ───────────────────

    match /accounting_customer_balances/{docId} {
      allow read:   if canReadAccounting(resource.data.companyId);
      allow create: if canCreateAccountingSystem();
      allow update: if canUpdateAccountingSystem(resource.data.companyId);
      // Customer balances are system-managed, admin can delete
      allow delete: if isCompanyAdminOfCompany(resource.data.companyId);
    }

    // =========================================================================
    // 🔒 HELPER FUNCTIONS - VALIDATION & SECURITY
    // =========================================================================

    // Project Data Validation
    function isValidProjectData(data) {
      return data.keys().hasAll(['name', 'status', 'company'])
             && data.name is string && data.name.size() > 0
             && data.status in ['planning', 'in_progress', 'completed', 'on_hold', 'cancelled']
             && data.company is string && data.company.size() > 0;
    }

    // Relationship Data Validation
    // 📅 Updated: 2026-02-13 — Expanded to match all 30+ RelationshipType values
    function isValidRelationshipData(data) {
      return data.keys().hasAll(['sourceContactId', 'targetContactId', 'relationshipType', 'status'])
             && data.sourceContactId is string && data.sourceContactId.size() > 0
             && data.targetContactId is string && data.targetContactId.size() > 0
             && data.relationshipType is string && data.relationshipType.size() > 0
             && data.status in ['active', 'inactive', 'pending', 'deleted'];
    }

    // 🎨 Enterprise CAD File Data Validation (Firebase Storage + Metadata Only)
    function isValidCadFileData(data) {
      return data.keys().hasAll(['fileName'])
             && data.fileName is string && data.fileName.size() > 0
             // 🚨 ΚΡΙΣΙΜΟ: ΔΕΝ επιτρέπουμε scene object στο Firestore! (Μπακάλικο γειτονιάς)
             && !data.keys().hasAny(['scene'])
             // ✅ ENTERPRISE: Firebase Storage-based validation
             && (
               // Legacy format (Firestore-based data)
               !data.keys().hasAny(['storageUrl']) ||
               // 🏢 ENTERPRISE FORMAT: Firebase Storage με metadata
               (data.keys().hasAll(['storageUrl'])
                && data.storageUrl is string
                && data.storageUrl.size() > 0
                // ✅ Validate Firebase Storage URL format
                && data.storageUrl.matches('https://firebasestorage.googleapis.com/.*'))
             )
             // ✅ Enterprise metadata validation
             && (!data.keys().hasAny(['version']) || (data.version is number && data.version > 0))
             && (!data.keys().hasAny(['sizeBytes']) || (data.sizeBytes is number && data.sizeBytes > 0))
             && (!data.keys().hasAny(['entityCount']) || (data.entityCount is number && data.entityCount >= 0))
             && (!data.keys().hasAny(['checksum']) || (data.checksum is string && data.checksum.size() > 0));
    }

    // Contact Data Validation
    // 🏢 ENTERPRISE: Updated for tenant isolation (ADR-029)
    // companyId is required for new contacts (tenant isolation)
    function isValidContactData(data) {
      return data.keys().hasAll(['companyId'])
             && data.companyId is string
             && data.companyId.size() > 0
             // Email validation (if present) - allows empty string
             && (!data.keys().hasAny(['email']) || data.email == '' || (data.email is string && data.email.matches('.*@.*\\..*')))
             // Type validation (if present)
             && (!data.keys().hasAny(['type']) || data.type in ['individual', 'company', 'service'])
             // Status validation (if present)
             && (!data.keys().hasAny(['status']) || data.status in ['active', 'inactive', 'archived']);
    }

    // ✅ Task Data Validation (ADR-026: CRM Tasks Backend Fix)
    // 🏢 ENTERPRISE: Validates CrmTask structure for Firestore operations
    function isValidTaskData(data) {
      return data.keys().hasAll(['title', 'type', 'assignedTo', 'status', 'priority'])
             // 📝 Title validation
             && data.title is string && data.title.size() > 0
             // 📋 Type validation (enum)
             && data.type in ['call', 'email', 'meeting', 'viewing', 'document', 'follow_up', 'other']
             // 👤 AssignedTo validation (User ID)
             && data.assignedTo is string && data.assignedTo.size() > 0
             // 📊 Status validation (enum)
             && data.status in ['pending', 'in_progress', 'completed', 'cancelled']
             // ⚡ Priority validation (enum)
             && data.priority in ['low', 'medium', 'high', 'urgent']
             // 🔗 Optional leadId validation
             && (!data.keys().hasAny(['leadId']) || data.leadId is string || data.leadId == null)
             // 🔗 Optional contactId validation
             && (!data.keys().hasAny(['contactId']) || data.contactId is string || data.contactId == null)
             // 🔗 Optional projectId validation
             && (!data.keys().hasAny(['projectId']) || data.projectId is string || data.projectId == null)
             // 📝 Optional description validation
             && (!data.keys().hasAny(['description']) || data.description is string || data.description == null);
    }

    // =========================================================================
    // 💬 CONVERSATION & MESSAGE DATA VALIDATION
    // =========================================================================
    // 📋 CRM Communications - Added 2026-01-15
    // 🏢 ENTERPRISE: Validates Conversation and Message structures for Firestore operations

    // Conversation Data Validation
    function isValidConversationData(data) {
      return data.keys().hasAll(['channel', 'status'])
             // 📡 Channel validation (enum: telegram | email | whatsapp | sms)
             && data.channel in ['telegram', 'email', 'whatsapp', 'sms']
             // 📊 Status validation (enum)
             && data.status in ['active', 'archived', 'closed', 'spam']
             // 🔢 Optional messageCount validation
             && (!data.keys().hasAny(['messageCount']) || (data.messageCount is int && data.messageCount >= 0))
             // 🔔 Optional unreadCount validation
             && (!data.keys().hasAny(['unreadCount']) || (data.unreadCount is int && data.unreadCount >= 0))
             // 👤 Optional assignedTo validation
             && (!data.keys().hasAny(['assignedTo']) || (data.assignedTo == null || data.assignedTo is string));
    }

    // Message Data Validation
    function isValidMessageData(data) {
      return data.keys().hasAll(['conversationId', 'direction', 'channel', 'content'])
             // 🔗 ConversationId validation
             && data.conversationId is string && data.conversationId.size() > 0
             // ↔️ Direction validation (enum: inbound | outbound)
             && data.direction in ['inbound', 'outbound']
             // 📡 Channel validation (enum)
             && data.channel in ['telegram', 'email', 'whatsapp', 'sms']
             // 📝 Content validation (must have text field)
             && data.content is map
             && data.content.keys().hasAll(['text'])
             && data.content.text is string
             // 👤 Optional sender fields validation
             && (!data.keys().hasAny(['senderId']) || (data.senderId is string))
             && (!data.keys().hasAny(['senderName']) || (data.senderName is string))
             // 📊 Optional deliveryStatus validation
             && (!data.keys().hasAny(['deliveryStatus'])
                 || data.deliveryStatus in ['queued', 'sent', 'delivered', 'read', 'failed']);
    }

    // =========================================================================
    // 🔔 NOTIFICATION UPDATE VALIDATION
    // =========================================================================
    // 📋 ADR-027: CRM Notifications Integration - Added 2026-01-13
    // 🔒 ENTERPRISE: Only allows updating delivery state fields
    function isValidNotificationUpdate(newData, existingData) {
      // List of fields that users are allowed to modify
      let allowedFields = ['delivery', 'seenAt', 'actedAt', 'actionId', 'dismissedAt'];

      // Get the fields that changed
      let changedKeys = newData.diff(existingData).affectedKeys();

      // All changed fields must be in the allowed list
      return changedKeys.hasOnly(allowedFields)
             // Ensure delivery state is valid if being updated
             && (!changedKeys.hasAny(['delivery'])
                 || newData.delivery.state in ['queued', 'sent', 'delivered', 'seen', 'acted', 'dismissed', 'failed', 'expired'])
             // Ensure userId is never changed
             && newData.userId == existingData.userId
             // Ensure title is never changed
             && newData.title == existingData.title;
    }

    // System Fields Protection
    // 📅 Fixed 2026-04-11 (ADR-298 Phase D.2) — CEL semantics:
    // `List.hasAny(X)` requires X to also be a List, but `MapDiff.affectedKeys()`
    // returns a Set, so the previous shape `systemFields.hasAny(affectedKeys())`
    // threw `Unsupported operation error. Received: list.hasAny(set).` at runtime
    // and denied every tenant_direct update that walked this helper (latent
    // production bug surfaced by the Phase A emulator suite). The canonical
    // form is `Set.hasAny(List)` — swap receiver and argument.
    function isAttemptingToModifySystemFields(newData, existingData) {
      let systemFields = ['createdAt', 'createdBy', 'ownerId', 'id'];
      return newData.diff(existingData).affectedKeys().hasAny(systemFields);
    }

    // Relationship checking helper
    function hasRelationshipWithContact(userId, contactId) {
      // This would need to be implemented based on your relationship logic
      // For now, allowing basic access - you can refine this later
      return true;
    }

    // =========================================================================
    // 🏗️ DEVELOPMENT MODE HELPERS
    // =========================================================================

    // Dev mode helper - PRODUCTION MODE ENABLED
    function isDevMode() {
      // 🔒 PRODUCTION: Dev mode disabled for security
      // Changed from true → false on 2026-01-11 (Security Audit Fix)
      return false;
    }

    // Authentication helper
    function isAuthenticated() {
      return request.auth != null;
    }

    // User ownership helper
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // =========================================================================
    // 🔐 RFC v6 AUTHORIZATION HELPERS (PHASE 1 PREPARATION)
    // =========================================================================
    // These helpers enable future tenant-scoped access control.
    // Path migration: /collection/{id} → /companies/{companyId}/collection/{id}
    //
    // @see docs/rfc/authorization-rbac.md

    // Get user's companyId from custom claims
    function getUserCompanyId() {
      return request.auth.token.companyId;
    }

    // Get user's globalRole from custom claims
    function getGlobalRole() {
      return request.auth.token.globalRole;
    }

    // Check if user is super_admin (system-wide access)
    function isSuperAdminOnly() {
      return isAuthenticated() && getGlobalRole() == 'super_admin';
    }

    // Check if user is company_admin or higher
    function isCompanyAdmin() {
      return isAuthenticated() && getGlobalRole() in ['super_admin', 'company_admin'];
    }

    // Check if user is internal_user or higher
    function isInternalUser() {
      return isAuthenticated() && getGlobalRole() in ['super_admin', 'company_admin', 'internal_user'];
    }

    // Check if user belongs to a specific company (tenant isolation)
    function belongsToCompany(companyId) {
      return isAuthenticated() && getUserCompanyId() == companyId;
    }

    // P0-B FIX: Tenant-bound company admin (prevents cross-tenant writes)
    function isCompanyAdminOfCompany(companyId) {
      return isSuperAdminOnly() ||
             (getGlobalRole() == 'company_admin' && belongsToCompany(companyId));
    }

    // P0-B FIX: Tenant-bound internal user (prevents cross-tenant reads)
    function isInternalUserOfCompany(companyId) {
      return isSuperAdminOnly() ||
             (isInternalUser() && belongsToCompany(companyId));
    }

    // =========================================================================
    // 📒 ACCOUNTING MODULE — TENANT ISOLATION HELPERS (Q3/Q4/Q7)
    // =========================================================================
    // 📅 Added: 2026-03-31 (AUDIT-2026-03-29, Εργασία #17 B-7)
    // 🔒 RBAC: super_admin/company_admin: full, internal_user: R/W, external_user: zero
    // 🏢 Pattern: companyId field-based isolation (Google pattern A)

    // Accounting: tenant-scoped read (internal_user+)
    function canReadAccounting(companyId) {
      return isSuperAdminOnly() || isInternalUserOfCompany(companyId);
    }

    // Accounting: tenant-scoped create (companyId + createdBy must match claims)
    function canCreateAccounting() {
      return isInternalUser()
             && request.resource.data.companyId is string
             && request.resource.data.companyId == getUserCompanyId()
             && request.resource.data.createdBy is string
             && request.resource.data.createdBy == request.auth.uid;
    }

    // Accounting: tenant-scoped create without createdBy (system-generated docs)
    function canCreateAccountingSystem() {
      return isInternalUser()
             && request.resource.data.companyId is string
             && request.resource.data.companyId == getUserCompanyId();
    }

    // Accounting: tenant-scoped update (creator or admin, companyId immutable)
    function canUpdateAccounting(companyId, createdBy) {
      return (request.auth.uid == createdBy || isCompanyAdminOfCompany(companyId))
             && request.resource.data.companyId == companyId;
    }

    // Accounting: tenant-scoped update without createdBy check (system docs)
    function canUpdateAccountingSystem(companyId) {
      return isInternalUserOfCompany(companyId)
             && request.resource.data.companyId == companyId;
    }

    // Accounting: delete — creator deletes own, admin deletes all (Q6 Xero/QBO pattern)
    function canDeleteAccounting(companyId, createdBy) {
      return request.auth.uid == createdBy || isCompanyAdminOfCompany(companyId);
    }

    // Accounting: admin-only write for settings/config singletons
    function canWriteAccountingSingleton(companyId) {
      return isCompanyAdminOfCompany(companyId);
    }

    // =========================================================================
    // 🏠 PROPERTY FIELDS SECURITY HELPERS (2026-01-24, renamed 2026-04-01)
    // =========================================================================
    // These helpers enable tenant-scoped access for properties via project→company lookup
    // Properties don't have companyId directly - must lookup via project reference

    // Get companyId from a project document (for tenant isolation)
    // Usage: getProjectCompanyId(resource.data.project) where project is the project ID string
    function getProjectCompanyId(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.companyId;
    }

    // Check if user belongs to the company that owns this project
    function belongsToProjectCompany(projectId) {
      return isSuperAdminOnly() || belongsToCompany(getProjectCompanyId(projectId));
    }

    // Check if user is company admin of the project's company
    function isCompanyAdminOfProject(projectId) {
      return isCompanyAdminOfCompany(getProjectCompanyId(projectId));
    }

    // =========================================================================
    // 🏢 BUILDING LOOKUP HELPERS (PR-1D: floors, storage_units, parking_spots)
    // =========================================================================
    // 📅 Added: 2026-01-29 (Security Gate Phase 1 - PR-1D)
    // 🏢 ENTERPRISE: Similar pattern to project lookup, with project fallback
    //
    // Get the companyId from a building document
    // Handles both direct companyId and projectId fallback
    function getBuildingCompanyId(buildingId) {
      let building = get(/databases/$(database)/documents/buildings/$(buildingId)).data;
      // If building has direct companyId, use it
      // Otherwise, fall back to project lookup
      return building.keys().hasAny(['companyId'])
             ? building.companyId
             : getProjectCompanyId(building.projectId);
    }

    // Check if user belongs to the company that owns this building
    function belongsToBuildingCompany(buildingId) {
      return isSuperAdminOnly() || belongsToCompany(getBuildingCompanyId(buildingId));
    }

    // Property Fields allowlist - only these fields can be updated by non-super-admin users
    // 🏢 ENTERPRISE: Prevents modification of structural fields (project, id)
    // 📅 Updated 2026-01-24: Added 'name' to allowlist (rename is allowed for company admins)
    // 📅 Updated 2026-01-24: Added buildingId, floorId, linkedSpaces for Property Linking System
    function isAllowedPropertyFieldUpdate() {
      let allowedFields = [
        // Identity (editable by company admins)
        'name', 'description',
        // Unit Linking System (Phase 1-2) - Building/Floor/LinkedSpaces
        'buildingId', 'floorId', 'linkedSpaces',
        // Phase 1-5 Unit Fields
        'bedrooms', 'bathrooms', 'wc',
        'areas', 'orientation', 'orientations', 'condition', 'energyClass',
        'heating', 'cooling', 'flooring', 'frames', 'glazing',
        'interiorFeatures', 'securityFeatures',
        // Layout
        'layout',
        // Systems & Finishes
        'systemsOverride', 'finishes', 'energy',
        // Metadata
        'updatedAt', 'updatedBy',
        // Operational
        'operationalStatus', 'unitCoverage'
      ];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    // Check that structural fields are not being modified (invariants)
    // 🏢 ENTERPRISE: Prevents "re-tenanting" properties via client update
    // 📅 Updated 2026-01-24: Removed 'name' from invariants (rename is now allowed)
    // 📅 Updated 2026-01-24: Removed buildingId/floorId from invariants (Property Linking System)
    //    - Properties CAN be moved between buildings/floors within the SAME project
    //    - Properties CANNOT be moved to a different project (tenant isolation)
    function propertyStructuralFieldsUnchanged() {
      return request.resource.data.project == resource.data.project
             && request.resource.data.id == resource.data.id;
    }

    // Validate parent document exists (for subcollections - prevents injection)
    function parentExists(path) {
      return exists(path);
    }
  }
}
