rules_version = '2';

// =============================================================================
// 🔒 PRODUCTION-GRADE FIRESTORE SECURITY RULES
// =============================================================================
//
// 🎯 ΣΤΡΑΤΗΓΙΚΗ: Deny-all by default, explicit allow per collection
// 🛡️ ΑΡΧΗ: Zero Trust - καμία πρόσβαση χωρίς authentication & authorization
// ⚠️ ΚΡΙΣΙΜΟ: Αυτές οι rules προστατεύουν την εφαρμογή από unauthorized access
//
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // 🚫 DEFAULT DENY-ALL RULE
    // =========================================================================
    // Οποιαδήποτε συλλογή που ΔΕΝ έχει explicit rule → ΑΡΝΗΣΗ
    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================================================
    // 📁 PROJECTS COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1B)
    // =========================================================================
    // 🔒 SECURITY: Tenant-scoped access via companyId field
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1B)
    // 🏢 ENTERPRISE: Follows /files pattern (lines 121-226)
    //
    // Security Model:
    //   - READ: Only users from the project's company (tenant-scoped)
    //   - CREATE: companyId must match user's company claim
    //   - UPDATE: Creator or company admin, companyId immutable
    //   - DELETE: Creator or company admin
    // =========================================================================
    match /projects/{projectId} {

      // 📖 READ: Tenant-scoped - only users from the project's company
      // 🔒 SECURITY: Prevents cross-tenant data leak
      allow read: if isAuthenticated()
                  && (
                       // Super admin can read all projects
                       isSuperAdminOnly()
                       // OR user belongs to the project's company
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // LEGACY FALLBACK (TRANSITIONAL - STRICT):
                       // Projects without companyId - creator-only get access
                       // ⚠️ NOTE: Requires data migration
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.keys().hasAny(['createdBy'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE: Authenticated users with companyId from claims
      // 🔐 SECURITY: companyId MUST match user's company claim (no cross-tenant creation)
      // 🏢 EXCEPTION: Super Admin can create projects for any company
      allow create: if isAuthenticated()
                    && isValidProjectData(request.resource.data)
                    && resource == null
                    && (
                         // Super Admin can create for any company
                         isSuperAdminOnly()
                         // OR user creates for their own company
                         || request.resource.data.companyId == getUserCompanyId()
                       );

      // 📝 UPDATE: Creator or company admin with tenant check
      // 🔐 SECURITY: companyId is immutable (no re-tenanting)
      allow update: if isAuthenticated()
                    && isValidProjectData(request.resource.data)
                    && resource != null
                    && (
                         // Creator can always update
                         resource.data.createdBy == request.auth.uid
                         // OR company admin of project's company
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         // OR super admin
                         || isSuperAdminOnly()
                       )
                    && !isAttemptingToModifySystemFields(request.resource.data, resource.data)
                    // Prevent changing companyId (no re-tenanting)
                    && (!resource.data.keys().hasAny(['companyId'])
                        || request.resource.data.companyId == resource.data.companyId);

      // 🗑️ DELETE: Creator or company admin
      allow delete: if isAuthenticated()
                    && resource != null
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       );
    }

    // =========================================================================
    // 👥 CONTACT_RELATIONSHIPS COLLECTION - TENANT ISOLATION (ADR-252 FR-H3)
    // =========================================================================
    // 📅 Updated: 2026-03-20 (ADR-252 FR-H3 — tenant isolation on READ)
    // 🔒 Pattern: Tenant-scoped via companyId + createdBy ownership fallback
    // =========================================================================
    match /contact_relationships/{relationshipId} {

      // 📖 READ: Tenant-scoped
      // 🔒 SECURITY (ADR-252 FR-H3): Was `isAuthenticated()` → now tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.keys().hasAny(['createdBy'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE: Authenticated with required fields
      allow create: if isAuthenticated()
                    && resource == null
                    && request.resource.data.keys().hasAll(['sourceContactId', 'targetContactId', 'relationshipType', 'status'])
                    && request.resource.data.sourceContactId is string
                    && request.resource.data.targetContactId is string
                    && request.resource.data.relationshipType is string
                    && request.resource.data.status is string;

      // 📝 UPDATE: Creator or super admin
      allow update: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isSuperAdminOnly()
                         || resource.data.createdBy == 'system'
                       );

      // 🗑️ DELETE: Creator or super admin
      allow delete: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isSuperAdminOnly()
                         || resource.data.createdBy == 'system'
                       );
    }

    // =========================================================================
    // 🔗 CONTACT_LINKS COLLECTION - TENANT ISOLATION (ADR-252 FR-H3)
    // =========================================================================
    // Links contacts to entities (projects, companies, units) via AssociationService
    // Used by: IKA Workers tab, contact association features
    // Fields: sourceContactId, targetEntityType, targetEntityId, status, createdBy
    // 📅 Updated: 2026-03-20 (ADR-252 FR-H3 — tenant isolation on READ)
    // =========================================================================
    match /contact_links/{linkId} {

      // 📖 READ: Tenant-scoped
      // 🔒 SECURITY (ADR-252 FR-H3): Was `isAuthenticated()` → now tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.keys().hasAny(['createdBy'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE: Authenticated users with required fields
      allow create: if isAuthenticated()
                    && resource == null
                    && request.resource.data.keys().hasAll(['sourceContactId', 'status', 'createdBy'])
                    && request.resource.data.sourceContactId is string
                    && request.resource.data.status is string
                    && request.resource.data.createdBy is string;

      // 📝 UPDATE: Creator or super admin (e.g., status → 'inactive')
      allow update: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isSuperAdminOnly()
                       );

      // 🗑️ DELETE: Creator or super admin
      allow delete: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isSuperAdminOnly()
                       );
    }

    // =========================================================================
    // 📋 ATTENDANCE_EVENTS COLLECTION - IMMUTABLE AUDIT TRAIL (ADR-090 Phase 2)
    // =========================================================================
    // Append-only attendance events: check_in, check_out, break_start, break_end,
    // left_site, returned, exit_permission.
    // IMMUTABLE: Once created, events CANNOT be updated or deleted.
    // Legal compliance: Proof of worker presence for ΣΕΠΕ inspections & accidents.
    // =========================================================================
    match /attendance_events/{eventId} {

      // 📖 READ: Tenant-scoped via projectId
      // 🔒 SECURITY (ADR-252 FR-H3): Was `isAuthenticated()` → now tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       || (resource.data.keys().hasAny(['projectId'])
                           && resource.data.projectId is string
                           && belongsToProjectCompany(resource.data.projectId))
                     );

      // ✍️ CREATE: Authenticated + tenant-bound + cross-doc project ownership
      // 🔒 SECURITY (ADR-298 §8 Phase B.2, 2026-04-11): Was shape/enum validation
      // only — no tenant check. Latent gap: cross_tenant_admin could plant events
      // under any company. Fix = defense-in-depth: (a) require `companyId` in
      // payload, (b) payload companyId must match user's claim (super_admin
      // short-circuit via `isSuperAdminOnly()`), (c) cross-doc verify that the
      // referenced project actually belongs to the caller's tenant via
      // `belongsToProjectCompany()` — mirrors the read gate's second OR leg.
      // Production path (src/services/attendance/attendance-server-service.ts:317)
      // uses Admin SDK, which bypasses rules — this tightening affects only the
      // client surface (never exercised in production today, tightened defensively).
      allow create: if isAuthenticated()
                    && resource == null
                    && request.resource.data.keys().hasAll([
                         'companyId', 'projectId', 'contactId', 'eventType', 'method',
                         'timestamp', 'recordedBy', 'createdAt'
                       ])
                    && request.resource.data.companyId is string
                    && request.resource.data.projectId is string
                    && request.resource.data.contactId is string
                    && (
                         isSuperAdminOnly()
                         || request.resource.data.companyId == getUserCompanyId()
                       )
                    && belongsToProjectCompany(request.resource.data.projectId)
                    && request.resource.data.eventType in [
                         'check_in', 'check_out', 'break_start', 'break_end',
                         'left_site', 'returned', 'exit_permission'
                       ]
                    && request.resource.data.method in ['manual', 'qr', 'geofence', 'nfc']
                    && request.resource.data.recordedBy is string;

      // 🚫 UPDATE: FORBIDDEN — immutable events
      allow update: if false;

      // 🚫 DELETE: FORBIDDEN — immutable events
      allow delete: if false;
    }

    // =========================================================================
    // 🔑 ATTENDANCE_QR_TOKENS COLLECTION — Daily QR tokens (ADR-170)
    // =========================================================================
    // QR tokens for worker attendance check-in.
    // Generated by admin, consumed by workers scanning QR at site entrance.
    // Server-managed lifecycle: active → expired/revoked.
    // =========================================================================
    match /attendance_qr_tokens/{tokenId} {

      // 📖 READ: Tenant-scoped via projectId or companyId
      // 🔒 SECURITY (ADR-252 FR-H3): Was `isAuthenticated()` → now tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       || (resource.data.keys().hasAny(['projectId'])
                           && resource.data.projectId is string
                           && belongsToProjectCompany(resource.data.projectId))
                     );

      // 🚫 CREATE/UPDATE/DELETE: Server-only via Admin SDK
      // Tokens are managed exclusively by the server (API routes)
      // to ensure HMAC integrity and prevent client-side manipulation.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // =========================================================================
    // 💰 EMPLOYMENT_RECORDS COLLECTION — Monthly employment records (Phase 3)
    // =========================================================================
    // Monthly employment records per worker per project.
    // Contains stamps count, insurance class, and contribution calculations.
    // Used by: StampsCalculationTabContent, ApdPaymentsTabContent
    // =========================================================================
    match /employment_records/{recordId} {

      // 📖 READ: Tenant-scoped via projectId
      // 🔒 SECURITY (ADR-252 FR-H3): Was `isAuthenticated()` → now tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       || (resource.data.keys().hasAny(['projectId'])
                           && resource.data.projectId is string
                           && belongsToProjectCompany(resource.data.projectId))
                     );

      // ✍️ CREATE: Authenticated user with required fields
      allow create: if isAuthenticated()
                    && resource == null
                    && request.resource.data.keys().hasAll([
                         'projectId', 'contactId', 'month', 'year',
                         'totalDaysWorked', 'insuranceClassNumber', 'stampsCount',
                         'employerContribution', 'employeeContribution', 'totalContribution',
                         'apdStatus', 'createdAt', 'updatedAt'
                       ])
                    && request.resource.data.projectId is string
                    && request.resource.data.contactId is string
                    && request.resource.data.month is number
                    && request.resource.data.year is number
                    && request.resource.data.apdStatus in [
                         'pending', 'submitted', 'accepted', 'rejected', 'corrected'
                       ];

      // ✏️ UPDATE: Authenticated user (for APD status changes, corrections)
      allow update: if isAuthenticated()
                    && request.resource.data.projectId == resource.data.projectId
                    && request.resource.data.contactId == resource.data.contactId;

      // 🚫 DELETE: FORBIDDEN — employment records are legal documents
      allow delete: if false;
    }

    // =========================================================================
    // 🎨 CAD_FILES COLLECTION - ENTERPRISE TENANT ISOLATION (ADR-252 FR-C1)
    // =========================================================================
    // Internal storage for DXF scene metadata (actual scene data in Firebase Storage)
    // Used by: DxfFirestoreService, BuildingFloorplanService, FloorFloorplanService
    // 📅 Updated: 2026-03-20 (ADR-252 Security Fixes — tenant isolation)
    // =========================================================================
    match /cad_files/{fileId} {

      // 📖 READ: Tenant-scoped via companyId or creator fallback
      // 🔒 SECURITY (ADR-252 FR-C1): Was `auth != null` → now tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // LEGACY FALLBACK: cad_files without companyId — creator only
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.keys().hasAny(['createdBy'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE/UPDATE: Authenticated users with basic validation + companyId
      allow create, update: if isAuthenticated()
                            && request.resource.data.keys().hasAll(['fileName'])
                            && request.resource.data.fileName is string
                            && request.resource.data.fileName.size() > 0;

      // 🗑️ DELETE: Tenant-scoped (creator or super admin)
      // 🔒 SECURITY (ADR-252 FR-C1): Was `auth != null` → now restricted
      allow delete: if isAuthenticated()
                    && (
                         isSuperAdminOnly()
                         || (resource.data.keys().hasAny(['companyId'])
                             && belongsToCompany(resource.data.companyId))
                         || (!resource.data.keys().hasAny(['companyId'])
                             && resource.data.keys().hasAny(['createdBy'])
                             && resource.data.createdBy == request.auth.uid)
                       );
    }

    // =========================================================================
    // 📁 FILES COLLECTION - ENTERPRISE CANONICAL FILE STORAGE (ADR-031)
    // =========================================================================
    // This collection stores FileRecord metadata (Source of Truth for file uploads)
    // Binary files are stored in Firebase Storage, metadata in Firestore
    //
    // Flow:
    // 1. CREATE: Client creates pending record (status: pending)
    // 2. Storage Upload: Binary uploaded to canonical path (Storage rules verify FileRecord)
    // 3. UPDATE: Client finalizes record (status: ready)
    // =========================================================================
    match /files/{fileId} {

      // 📖 READ: Users belonging to file's company (tenant isolation)
      // 🏢 ENTERPRISE: Allow company members OR creator (for pending files during upload)
      // This enables both:
      // - Storage Rules to validate uploads via firestore.get() (pending files)
      // - Users to list/view ready files from their company
      allow read: if isAuthenticated()
                  && (
                       // Super admin can read everything — no companyId constraint needed
                       isSuperAdminOnly()
                       // Company members can read files from their company
                       || (
                            resource.data.keys().hasAny(['companyId'])
                            && belongsToCompany(resource.data.companyId)
                          )
                     );

      // ✍️ CREATE: Users can create pending FileRecord for their company
      // 🔐 SECURITY: createdBy must match request.auth.uid
      // 🔐 SECURITY: companyId must match user's company claim (OR super_admin)
      // 🔐 SECURITY: status must be 'pending' (no direct 'ready' creation)
      allow create: if isAuthenticated()
                    && request.resource.data.createdBy == request.auth.uid
                    && (
                         request.resource.data.companyId == getUserCompanyId()
                         // super_admin can create files for any company (cross-tenant admin)
                         || isSuperAdminOnly()
                       )
                    && request.resource.data.status == 'pending'
                    && resource == null; // Ensure document doesn't exist

      // 📝 UPDATE: Only creator or company admin can finalize
      // 🔐 SECURITY: Limited to specific fields for finalization
      // 🔐 SECURITY: Can only transition pending → ready (or → failed)
      allow update: if isAuthenticated()
                    && (
                         resource.data.companyId == getUserCompanyId()
                         // super_admin can finalize files for any company
                         || isSuperAdminOnly()
                       )
                    && (
                         // Creator can finalize
                         resource.data.createdBy == request.auth.uid
                         // OR company admin can finalize
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         // OR super_admin can finalize
                         || isSuperAdminOnly()
                       )
                    // Status transitions: pending → ready OR pending → failed
                    && (
                         (resource.data.status == 'pending' && request.resource.data.status == 'ready')
                         || (resource.data.status == 'pending' && request.resource.data.status == 'failed')
                       )
                    // Prevent modification of immutable fields
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.companyId == resource.data.companyId
                    && request.resource.data.createdBy == resource.data.createdBy
                    && request.resource.data.storagePath == resource.data.storagePath;

      // 🗑️ MOVE TO TRASH: Creator or company admin can trash ready files
      // 🏢 ENTERPRISE: Ownership Principle (SAP/Salesforce/Google Drive pattern)
      //    - Creator can ALWAYS manage their own files (no claims required)
      //    - Admins need proper company claims for cross-user operations
      // 🔐 SECURITY: Only allows setting isDeleted flag, preserves all other immutable fields
      allow update: if isAuthenticated()
                    && (
                         // OWNERSHIP PRINCIPLE: Creator can ALWAYS trash their own files
                         resource.data.createdBy == request.auth.uid
                         // OR company admin can trash any file in their company (requires claims)
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         // OR super_admin can trash anything
                         || isSuperAdminOnly()
                       )
                    // Only for ready files (soft delete)
                    && resource.data.status == 'ready'
                    // Must be setting isDeleted to true
                    && request.resource.data.isDeleted == true
                    // Preserve immutable fields
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.companyId == resource.data.companyId
                    && request.resource.data.createdBy == resource.data.createdBy
                    && request.resource.data.storagePath == resource.data.storagePath
                    && request.resource.data.status == resource.data.status;

      // ♻️ RESTORE FROM TRASH: Creator or company admin can restore trashed files
      // 🏢 ENTERPRISE: Ownership Principle (SAP/Salesforce/Google Drive pattern)
      //    - Creator can ALWAYS restore their own files (no claims required)
      //    - Admins need proper company claims for cross-user operations
      // 📅 Added: 2026-01-20 (ADR-032 - Enterprise Trash System)
      allow update: if isAuthenticated()
                    && (
                         // OWNERSHIP PRINCIPLE: Creator can ALWAYS restore their own files
                         resource.data.createdBy == request.auth.uid
                         // OR company admin can restore any file in their company (requires claims)
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         // OR super_admin can restore anything
                         || isSuperAdminOnly()
                       )
                    // Only for trashed files (isDeleted == true)
                    && resource.data.isDeleted == true
                    // Must be setting isDeleted to false (restoring)
                    && request.resource.data.isDeleted == false
                    // Preserve immutable fields
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.companyId == resource.data.companyId
                    && request.resource.data.createdBy == resource.data.createdBy
                    && request.resource.data.storagePath == resource.data.storagePath
                    && request.resource.data.status == resource.data.status;

      // 🔗 LINK/UNLINK: Company members can update linkedTo on ready files
      // 🏢 ENTERPRISE: Entity linking — one file in storage, multiple display points
      // Only allows modifying linkedTo field (and updatedAt), preserves all immutable fields
      allow update: if isAuthenticated()
                    && (
                         resource.data.companyId == getUserCompanyId()
                         || isSuperAdminOnly()
                       )
                    // Only for ready, non-deleted files
                    && resource.data.status == 'ready'
                    && resource.data.isDeleted != true
                    // Preserve immutable fields
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.companyId == resource.data.companyId
                    && request.resource.data.createdBy == resource.data.createdBy
                    && request.resource.data.storagePath == resource.data.storagePath
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.isDeleted == resource.data.isDeleted;

      // 🗑️ HARD DELETE: Only creator or company admin
      allow delete: if isAuthenticated()
                    && resource.data.companyId == getUserCompanyId()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                       );
    }

    // =========================================================================
    // 🏢 COMPANIES COLLECTION - TENANT-SCOPED READ (ADR-252 FR-C3)
    // =========================================================================
    // 📅 Updated: 2026-03-20 (ADR-252 FR-C3 — own company only)
    // 🔒 SECURITY: Users can only read their OWN company document
    match /companies/{companyId} {

      // 📖 READ: Own company only (token.companyId must match document ID)
      // 🔒 SECURITY (ADR-252 FR-C3): Was `auth != null` → now tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || getUserCompanyId() == companyId
                     );

      // ✍️ CREATE/UPDATE/DELETE: ΌΧΙ από client - μόνο admin/server
      allow write: if false;

      // =========================================================================
      // 📋 AUDIT_LOGS SUBCOLLECTION - COMPANY-SCOPED AUDIT TRAIL
      // =========================================================================
      // 🏢 ENTERPRISE: Audit logs for company operations (ADR-029 Global Search)
      // 📅 Added: 2026-01-26
      // 🔒 SECURITY: Only users from the same company can read/write audit logs
      match /audit_logs/{logId} {
        // 📖 READ: Company members and super_admin
        allow read: if isAuthenticated()
                    && (belongsToCompany(companyId) || isSuperAdminOnly());

        // ✍️ CREATE: Company members can create audit entries
        // 🔐 SECURITY: Used by API routes for audit logging
        allow create: if isAuthenticated()
                      && belongsToCompany(companyId);

        // 📝 UPDATE/DELETE: Not allowed - audit logs are immutable
        allow update, delete: if false;
      }
    }

    // =========================================================================
    // 🏠 BUILDINGS COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1A Critical Hotfix)
    // =========================================================================
    // 🔒 SECURITY: Removed public read (was: `allow read: if true;`)
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1A)
    // 🏢 ENTERPRISE: Follows /files pattern (lines 121-226)
    //
    // Security Model:
    //   - READ: Only users from the building's company (tenant-scoped)
    //   - WRITE: Admin/server only (via Firebase Admin SDK)
    // =========================================================================
    match /buildings/{buildingId} {

      // 📖 READ: Tenant-scoped - only users from the building's company
      // 🔒 SECURITY: Prevents cross-tenant data leak
      allow read: if isAuthenticated()
                  && (
                       // Super admin can read all buildings
                       isSuperAdminOnly()
                       // OR user belongs to the building's company (PRIMARY path)
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // LEGACY FALLBACK (TRANSITIONAL - STRICT):
                       // Buildings without companyId but with projectId - lookup via project
                       // ⚠️ NOTE: Requires data migration - see docs/architecture-review/migration-companyId.md
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.keys().hasAny(['projectId'])
                           && resource.data.projectId is string
                           && belongsToProjectCompany(resource.data.projectId))
                     );

      // 🚫 WRITE: Admin/server only (via Firebase Admin SDK)
      // 🏢 ENTERPRISE: Building creation/modification requires admin privileges
      allow write: if false;
    }

    // =========================================================================
    // 🏢 FLOORS COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1D)
    // =========================================================================
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1D)
    // 🏢 ENTERPRISE: Tenant-scoped via building→company lookup
    //
    // Security Model:
    //   - READ: Only users from the building's company (tenant-scoped)
    //   - WRITE: Admin/server only (via Firebase Admin SDK)
    // =========================================================================
    match /floors/{floorId} {
      // 📖 READ: Tenant-scoped via building lookup
      // 🔒 SECURITY: Prevents cross-tenant data leak
      allow read: if isAuthenticated()
                  && (
                       // Super admin can read all
                       isSuperAdminOnly()
                       // OR user belongs to the building's company
                       || (resource.data.keys().hasAny(['buildingId'])
                           && resource.data.buildingId is string
                           && belongsToBuildingCompany(resource.data.buildingId))
                       // LEGACY FALLBACK: Creator-only for floors without buildingId
                       || (!resource.data.keys().hasAny(['buildingId'])
                           && resource.data.keys().hasAny(['createdBy'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // 🚫 WRITE: Admin/server only
      allow write: if false;
    }

    // =========================================================================
    // 🏠 UNITS COLLECTION - ENTERPRISE TENANT ISOLATION (2026-01-24)
    // =========================================================================
    // 🏢 ENTERPRISE: Full tenant isolation via project→company lookup
    // 📋 Security Model:
    //    - READ: Only users belonging to the project's company (tenant-scoped)
    //    - UPDATE: Company admins of project's company + field allowlist + invariants
    //    - CREATE/DELETE: Admin/server only (via Firebase Admin SDK)
    // 🔐 Invariants: project, buildingId, floorId, name, id cannot be changed by client
    // 📅 Implemented: 2026-01-24
    match /properties/{propertyId} {
      // 📖 READ: Tenant-scoped - only users from the project's company
      // 🔒 SECURITY: Prevents cross-tenant data leak
      allow read: if isAuthenticated()
                  && (
                       // Super admin can read all
                       isSuperAdminOnly()
                       // OR user belongs to the project's company
                       || belongsToProjectCompany(resource.data.project)
                     );

      // ✍️ CREATE: Admin/server only
      allow create: if false;

      // 📝 UPDATE: Company admin of project's company + field allowlist + invariants
      // 🔒 SECURITY LAYERS:
      //    1. Role gate: Must be company_admin or super_admin
      //    2. Tenant gate: Must belong to project's company
      //    3. Field allowlist: Only property fields can be updated (not structural fields)
      //    4. Invariants: Structural fields (project, buildingId, floorId, name, id) unchanged
      allow update: if isAuthenticated()
                    && (
                         // Super admin bypasses all checks
                         isSuperAdminOnly()
                         // OR company admin of project's company with allowlist + invariants
                         || (
                              isCompanyAdminOfProject(resource.data.project)
                              && isAllowedPropertyFieldUpdate()
                              && propertyStructuralFieldsUnchanged()
                            )
                       );

      // 🗑️ DELETE: Admin/server only
      allow delete: if false;
    }

    // =========================================================================
    // 📦 STORAGE_UNITS COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1D)
    // =========================================================================
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1D)
    // 🏢 ENTERPRISE: Storage units are a PARALLEL category to Properties, not nested
    // Architecture: Building → [Properties | Storage | Parking] (parallel)
    //
    // Security Model:
    //   - READ: Only users from the building's company (tenant-scoped)
    //   - WRITE: Admin/server only (via Firebase Admin SDK)
    // =========================================================================
    match /storage_units/{storageId} {
      // 📖 READ: Tenant-scoped via building lookup
      // 🔒 SECURITY: Prevents cross-tenant data leak
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['buildingId'])
                           && resource.data.buildingId is string
                           && belongsToBuildingCompany(resource.data.buildingId))
                       // LEGACY FALLBACK: Creator-only
                       || (!resource.data.keys().hasAny(['buildingId'])
                           && resource.data.keys().hasAny(['createdBy'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // 🚫 WRITE: Admin/server only
      allow write: if false;
    }

    // =========================================================================
    // 🚗 PARKING_SPOTS COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1D)
    // =========================================================================
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1D)
    // 🏢 ENTERPRISE: Parking spaces are a PARALLEL category to Units, not nested
    // Architecture: Building → [Units | Storage | Parking] (parallel)
    // 📍 Collection name: parking_spots (με underscore - όπως στη Firestore)
    //
    // Security Model:
    //   - READ: Only users from the building's company (tenant-scoped)
    //   - WRITE: Admin/server only (via Firebase Admin SDK)
    // =========================================================================
    match /parking_spots/{parkingId} {
      // 📖 READ: Tenant-scoped via building lookup
      // 🔒 SECURITY: Prevents cross-tenant data leak
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['buildingId'])
                           && resource.data.buildingId is string
                           && belongsToBuildingCompany(resource.data.buildingId))
                       // LEGACY FALLBACK: Creator-only
                       || (!resource.data.keys().hasAny(['buildingId'])
                           && resource.data.keys().hasAny(['createdBy'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // 🚫 WRITE: Admin/server only
      allow write: if false;
    }

    // =========================================================================
    // 🧭 NAVIGATION_COMPANIES COLLECTION - TENANT-SCOPED READ ACCESS
    // =========================================================================
    // 🏢 ENTERPRISE: Εταιρείες που εμφανίζονται χειροκίνητα στην πλοήγηση
    // Περιέχει contactIds που αντιστοιχούν σε εταιρείες στη contacts collection
    // 🔒 ADR-252 Phase 3: Tenant isolation — super_admin βλέπει όλα,
    //    οι υπόλοιποι μόνο τα documents με companyId == δικό τους
    match /navigation_companies/{navCompanyId} {
      allow read: if isAuthenticated()
                  && (isSuperAdminOnly()
                      || belongsToCompany(resource.data.companyId));
      allow write: if false; // Admin/server only
    }

    // =========================================================================
    // 🔔 NOTIFICATIONS COLLECTION - USER-SCOPED ACCESS
    // =========================================================================
    // 🏢 ENTERPRISE: Secure notification access per user
    // 🔒 AUTHENTICATED: User can only access their own notifications
    // 📋 ADR-027: CRM Notifications Integration - Updated 2026-01-13
    // ⚠️ NOTE: For list queries, the userId filter must be in the query itself
    //          (where userId == auth.uid). Rules validate single doc reads.
    match /notifications/{notificationId} {
      // 📖 READ: Authenticated users can read notifications
      // Query MUST include: where('userId', '==', currentUserId) for security
      // Single doc reads verify ownership
      allow read: if isAuthenticated()
                  && (resource == null || resource.data.userId == request.auth.uid);

      // 📝 UPDATE: Users can mark their own notifications as read
      // Only allows updating delivery state and seen timestamp
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid
                    && isValidNotificationUpdate(request.resource.data, resource.data);

      // 🔒 CREATE: Server-only via Admin SDK (notification-orchestrator.ts)
      // Client create blocked — prevents notification spam/injection
      allow create: if false;

      // 🔒 DELETE: Server-only via Admin SDK
      // Client-side cleanup unnecessary — server handles lifecycle
      allow delete: if false;
    }

    // =========================================================================
    // ✅ TASKS COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1B)
    // =========================================================================
    // 🏢 ENTERPRISE: Task management για CRM leads, projects, και users
    // 🔒 SECURITY: Tenant-scoped via companyId field
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1B)
    // 📋 ADR-026: CRM Tasks Backend Fix - Added 2026-01-13
    //
    // Security Model:
    //   - READ: Only users from the task's company + assignedTo
    //   - CREATE: companyId must match user's company claim
    //   - UPDATE: Creator, assignedTo, or company admin
    //   - DELETE: Creator or company admin
    // =========================================================================
    match /tasks/{taskId} {

      // 📖 READ: Creator, assignee, same company, or super admin
      // 🔐 SECURITY: Tenant-scoped access
      allow read: if isAuthenticated()
                  && (
                       // Super admin can read all tasks
                       isSuperAdminOnly()
                       // OR user is the creator
                       || resource.data.createdBy == request.auth.uid
                       // OR user is the assignee
                       || resource.data.assignedTo == request.auth.uid
                       // OR user belongs to the task's company
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                     );

      // ✍️ CREATE: Authenticated users with companyId from claims, or super admin
      // 🔐 SECURITY: companyId MUST match user's company claim (super admin exempt)
      allow create: if isAuthenticated()
                    && isValidTaskData(request.resource.data)
                    && resource == null
                    && (
                         request.resource.data.companyId == getUserCompanyId()
                         || isSuperAdminOnly()
                       );

      // 📝 UPDATE: Creator, assignee, or company admin
      allow update: if isAuthenticated()
                    && isValidTaskData(request.resource.data)
                    && resource != null
                    && (
                         // Creator can update
                         resource.data.createdBy == request.auth.uid
                         // OR assignee can update
                         || resource.data.assignedTo == request.auth.uid
                         // OR company admin
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         // OR super admin
                         || isSuperAdminOnly()
                       )
                    // Prevent changing companyId
                    && (!resource.data.keys().hasAny(['companyId'])
                        || request.resource.data.companyId == resource.data.companyId);

      // 🗑️ DELETE: Creator or company admin
      allow delete: if isAuthenticated()
                    && resource != null
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       );
    }

    // =========================================================================
    // 📅 APPOINTMENTS COLLECTION - ENTERPRISE TENANT ISOLATION (ADR-089)
    // =========================================================================
    // 🏢 ENTERPRISE: Appointments from AI Pipeline (UC-001) with tenant isolation
    // 📅 Added: 2026-02-08 (CRM Calendar MVP - ADR-089)
    // 🔒 SECURITY: Documents created server-side via Admin SDK (bypasses rules)
    //              Client-side READ only — tenant-scoped via companyId
    //
    // Security Model:
    //   - READ: Tenant-scoped (companyId match or super admin)
    //   - WRITE: Server-side only via Admin SDK (no client writes)
    // =========================================================================
    match /appointments/{appointmentId} {

      // 📖 READ: Tenant-scoped via companyId
      // 🔐 SECURITY: Only users from the appointment's company
      allow read: if isAuthenticated()
                  && (
                       // Super admin can read all appointments
                       isSuperAdminOnly()
                       // OR user belongs to the appointment's company
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                     );

      // 🚫 WRITE: Server-side only (Admin SDK bypasses rules)
      // Appointments are created by UC-001 pipeline via Admin SDK
      allow write: if false;
    }

    // =========================================================================
    // 📐 PROJECT_FLOORPLANS COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1C)
    // =========================================================================
    // 🏢 ENTERPRISE: Floorplans for projects with tenant isolation
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1C)
    // ⚠️ NOTE: Requires companyId migration - derive from projectId
    match /project_floorplans/{floorplanId} {
      // 📖 READ: Tenant-scoped via companyId or projectId lookup
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // Fallback via projectId lookup
                       || (resource.data.keys().hasAny(['projectId'])
                           && resource.data.projectId is string
                           && belongsToProjectCompany(resource.data.projectId))
                       // Legacy: creator-only
                       || (!resource.data.keys().hasAny(['companyId', 'projectId'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE: companyId required
      allow create: if isAuthenticated()
                    && request.resource.data.companyId == getUserCompanyId();

      // 📝 UPDATE: Creator or company admin
      allow update: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       )
                    && (!resource.data.keys().hasAny(['companyId'])
                        || request.resource.data.companyId == resource.data.companyId);

      // 🗑️ DELETE: Creator or company admin
      allow delete: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       );
    }

