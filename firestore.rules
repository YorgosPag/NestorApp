                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       )
                    && (!resource.data.keys().hasAny(['companyId'])
                        || request.resource.data.companyId == resource.data.companyId);

      // 🗑️ DELETE: Creator or company admin
      allow delete: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       );
    }

    // =========================================================================
    // 🔐 SECURITY_ROLES COLLECTION - ΚΡΙΣΙΜΟ ΓΙΑ LOGIN!
    // =========================================================================
    // 🏢 ENTERPRISE: Role-based access control για EnterpriseSecurityService
    match /security_roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin/server only
    }

    // =========================================================================
    // 👤 USERS COLLECTION & SESSIONS SUBCOLLECTION
    // =========================================================================
    // 🏢 ENTERPRISE: User profile και active sessions management
    // 🔒 OWNERSHIP-BASED: Κάθε χρήστης μπορεί να διαχειρίζεται ΜΟΝΟ τα δικά του
    match /users/{userId} {
      // 📖 READ: Own profile + same-company users + super admin (SPEC-259B)
      // 🔒 SECURITY: Tenant-scoped — prevents cross-company user enumeration
      // 📅 Updated: 2026-03-23 (SPEC-259B — Firestore Security Hardening)
      allow read: if isAuthenticated()
                  && (
                       // Own profile — always allowed
                       request.auth.uid == userId
                       // Same company — for team/colleague visibility
                       || (resource.data.keys().hasAny(['companyId'])
                           && resource.data.companyId != null
                           && belongsToCompany(resource.data.companyId))
                       // Super admin — system-wide access
                       || isSuperAdminOnly()
                     );

      // 📝 UPDATE: Own profile or company admin
      allow update: if isAuthenticated()
                    && (
                         request.auth.uid == userId
                         || (resource.data.keys().hasAny(['companyId'])
                             && resource.data.companyId != null
                             && isCompanyAdminOfCompany(resource.data.companyId))
                       );

      // ✅ CREATE: Own profile (signup) or company admin (invite)
      allow create: if isAuthenticated()
                    && (
                         request.auth.uid == userId
                         || (request.resource.data.keys().hasAny(['companyId'])
                             && request.resource.data.companyId != null
                             && isCompanyAdminOfCompany(request.resource.data.companyId))
                       );

      // 🗑️ DELETE: Απαγορεύεται — user documents δεν σβήνονται
      allow delete: if false;

      // 🔐 SESSIONS SUBCOLLECTION - Enterprise Active Sessions Management
      match /sessions/{sessionId} {
        // Ο χρήστης μπορεί να διαβάζει και να γράφει ΜΟΝΟ τα δικά του sessions
        allow read, write: if isOwner(userId);
      }
    }

    // =========================================================================
    // 🔐 USER_2FA_SETTINGS COLLECTION - Two-Factor Authentication
    // =========================================================================
    // 🏢 ENTERPRISE: 2FA settings και backup codes storage
    // 🔒 OWNERSHIP-BASED: Κάθε χρήστης μπορεί να διαχειρίζεται ΜΟΝΟ τα δικά του 2FA settings
    match /user_2fa_settings/{userId} {
      // Ο χρήστης μπορεί να διαβάζει και να γράφει ΜΟΝΟ τα δικά του 2FA settings
      allow read, write: if isOwner(userId);
    }

    // =========================================================================
    // 🔔 USER_NOTIFICATION_SETTINGS COLLECTION - Notification Preferences
    // =========================================================================
    // 🏢 ENTERPRISE: User notification preferences management
    // 🔒 OWNERSHIP-BASED: Κάθε χρήστης μπορεί να διαχειρίζεται ΜΟΝΟ τις δικές του ρυθμίσεις
    match /user_notification_settings/{userId} {
      // Ο χρήστης μπορεί να διαβάζει και να γράφει ΜΟΝΟ τις δικές του ρυθμίσεις ειδοποιήσεων
      allow read, write: if isOwner(userId);
    }

    // =========================================================================
    // 🏢 WORKSPACES COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1B)
    // =========================================================================
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1B)
    // 🏢 ENTERPRISE: Workspaces are company-scoped
    match /workspaces/{workspaceId} {
      // 📖 READ: Tenant-scoped (SPEC-259B — legacy fallback removed)
      // 🔒 SECURITY: Only same-company users or super admin
      // 📅 Updated: 2026-03-23 (SPEC-259B — removed dangerous legacy fallback)
      // ℹ️ Pre-check: 0 workspaces without companyId (2026-03-23)
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                     );

      // ✍️ WRITE: Admin/server only (via Firebase Admin SDK)
      allow write: if false;
    }

    // =========================================================================
    // 📞 CONTACTS COLLECTION - ENTERPRISE TENANT ISOLATION (ADR-029)
    // =========================================================================
    // 🏢 ENTERPRISE: Multi-tenant security via companyId field
    // 📅 Updated: 2026-01-26 (Global Search v1 - Tenant Isolation Fix)
    //
    // Security Model:
    //   - READ: Only users from the same company (tenant-scoped)
    //   - CREATE: Authenticated users, companyId auto-set from claims
    //   - UPDATE: Creator or company admin
    //   - DELETE: Creator or company admin
    // =========================================================================
    match /contacts/{contactId} {

      // 📖 READ: Tenant-scoped - only users from the contact's company
      // 🔒 SECURITY: Prevents cross-tenant data leak
      // 🏢 ENTERPRISE: Follows SAP/Salesforce/Microsoft multi-tenant patterns
      allow read: if isAuthenticated()
                  && (
                       // Super admin can read all contacts
                       isSuperAdminOnly()
                       // OR user belongs to the contact's company
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // LEGACY FALLBACK: Contacts without companyId readable by creator only
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE: Authenticated users with companyId from claims
      // 🔐 SECURITY: companyId MUST match user's company claim (no cross-tenant creation)
      // 🏢 EXCEPTION: Super Admin can create contacts for any company (same as projects)
      allow create: if isAuthenticated()
                    && isValidContactData(request.resource.data)
                    && resource == null
                    && (
                         // Super Admin can create for any company
                         isSuperAdminOnly()
                         // OR user creates for their own company
                         || request.resource.data.companyId == getUserCompanyId()
                       );

      // 📝 UPDATE: Creator or company admin of contact's company
      // 🔒 SECURITY: Prevents cross-tenant modification
      // 🏢 ENTERPRISE: isValidContactData + isAttemptingToModifySystemFields removed from update rule
      //    - isValidContactData: updateDoc partial writes cause false negatives on field checks
      //    - isAttemptingToModifySystemFields: diff() fails on complex updateDoc payloads
      //    Both are enforced at CREATE time + client-side cleanup in contacts.service.ts
      allow update: if isAuthenticated()
                    && (
                         // Creator can always update their contacts
                         resource.data.createdBy == request.auth.uid
                         // OR company admin can update contacts in their company
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         // OR super admin can update any contact
                         || isSuperAdminOnly()
                         // 🔄 LEGACY FALLBACK: Contacts without createdBy can be updated by same-company users
                         || (!resource.data.keys().hasAny(['createdBy']) && belongsToCompany(resource.data.companyId))
                       )
                    // Prevent changing companyId (no re-tenanting)
                    && request.resource.data.companyId == resource.data.companyId;

      // 🗑️ DELETE: Creator or company admin
      allow delete: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       );

      // =====================================================================
      // 🏦 BANK ACCOUNTS SUBCOLLECTION - INHERITS PARENT TENANT ISOLATION
      // =====================================================================
      // 🏢 ENTERPRISE: Bank accounts for contacts (2026-02-01)
      // 📁 Path: contacts/{contactId}/bank_accounts/{accountId}
      // 🔒 SECURITY: Inherits access from parent contact document
      // =====================================================================
      match /bank_accounts/{accountId} {

        // Helper: Check if user can access parent contact
        function canAccessParentContact() {
          let parentContact = get(/databases/$(database)/documents/contacts/$(contactId)).data;
          return isAuthenticated()
                 && (
                      isSuperAdminOnly()
                      || (parentContact.keys().hasAny(['companyId'])
                          && belongsToCompany(parentContact.companyId))
                      || (!parentContact.keys().hasAny(['companyId'])
                          && parentContact.createdBy == request.auth.uid)
                    );
        }

        // 📖 READ: Same access as parent contact
        allow read: if canAccessParentContact();

        // ✍️ CREATE: Users who can access parent contact
        allow create: if canAccessParentContact()
                      && request.resource.data.keys().hasAll(['bankName', 'iban', 'accountType', 'currency', 'isPrimary', 'isActive'])
                      && request.resource.data.iban is string
                      && request.resource.data.iban.size() >= 15;

        // 📝 UPDATE: Users who can access parent contact
        allow update: if canAccessParentContact()
                      && request.resource.data.keys().hasAll(['bankName', 'iban', 'accountType', 'currency', 'isPrimary', 'isActive']);

        // 🗑️ DELETE: Users who can access parent contact
        allow delete: if canAccessParentContact();
      }
    }

    // =========================================================================
    // =========================================================================
    // 💬 COMMUNICATIONS COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1B)
    // =========================================================================
    // 🏢 ENTERPRISE: Legacy CRM communications with tenant isolation
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1B)
    // ⚠️ NOTE: Requires companyId migration for legacy docs
    match /communications/{communicationId} {
      // 📖 READ: Tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // Legacy fallback: creator-only
                       || (!resource.data.keys().hasAny(['companyId'])
                           && resource.data.createdBy == request.auth.uid)
                     );

      // ✍️ CREATE: companyId required
      allow create: if isAuthenticated()
                    && request.resource.data.companyId == getUserCompanyId();

      // 📝 UPDATE: Creator or company admin
      allow update: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       )
                    && (!resource.data.keys().hasAny(['companyId'])
                        || request.resource.data.companyId == resource.data.companyId);

      // 🗑️ DELETE: Creator or company admin
      allow delete: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       );
    }

    // =========================================================================
    // ⚙️ SYSTEM COLLECTION - ADMIN-ONLY READ (ADR-252 FR-M1)
    // =========================================================================
    // 🏢 ENTERPRISE: System-wide configuration and templates
    // 📅 Updated: 2026-03-20 (ADR-252 FR-M1 — restrict to company admin)
    // 🔒 SECURITY: System config contains sensitive routing rules, integrations
    // NOTE: Merged duplicate block (was at lines ~1442 and ~2549)
    match /system/{docId} {
      allow read: if isAuthenticated() && isCompanyAdmin();
      allow write: if false; // Admin/server only

      // 📁 Subcollections (e.g., project-templates)
      match /{subcollection}/{subDocId} {
        allow read: if isAuthenticated() && isCompanyAdmin();
        allow write: if false; // Admin/server only
      }
    }

    // =========================================================================
    // ⚙️ CONFIG COLLECTION - APPLICATION CONFIGURATION
    // =========================================================================
    // 🏢 ENTERPRISE: Application configuration
    // 📅 Added: 2026-01-17 (Permission-denied fix)
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin/server only
    }

    // =========================================================================
    // 🎯 LEADS COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1B)
    // =========================================================================
    // 🏢 ENTERPRISE: CRM lead management with tenant isolation
    // 📅 Updated: 2026-01-29 (Security Gate Phase 1 - PR-1B)
    match /leads/{leadId} {
      // 📖 READ: Tenant-scoped
      allow read: if isAuthenticated()
                  && (
                       isSuperAdminOnly()
                       || (resource.data.keys().hasAny(['companyId'])
                           && belongsToCompany(resource.data.companyId))
                       // Legacy fallback: creator or assignee
                       || (!resource.data.keys().hasAny(['companyId'])
                           && (resource.data.createdBy == request.auth.uid
                               || resource.data.assignedTo == request.auth.uid))
                     );

      // ✍️ CREATE: companyId required
      allow create: if isAuthenticated()
                    && request.resource.data.companyId == getUserCompanyId();

      // 📝 UPDATE: Creator, assignee, or company admin
      allow update: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || resource.data.assignedTo == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       )
                    && (!resource.data.keys().hasAny(['companyId'])
                        || request.resource.data.companyId == resource.data.companyId);

      // 🗑️ DELETE: Creator or company admin
      allow delete: if isAuthenticated()
                    && (
                         resource.data.createdBy == request.auth.uid
                         || isCompanyAdminOfCompany(resource.data.companyId)
                         || isSuperAdminOnly()
                       );
    }

    // =========================================================================
    // 💼 OPPORTUNITIES COLLECTION - ENTERPRISE TENANT ISOLATION (PR-1B)
