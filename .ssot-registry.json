    "entity-audit-trail": {
      "ssotFile": "src/services/entity-audit.service.ts",
      "description": "Entity audit trail is a closed SSoT (ADR-195 Phase 10). Server writes go through EntityAuditService.recordChange(). Client reads go through EntityAuditClientService.subscribeGlobal()/subscribeEntity(), which compose firestoreQueryService. The canonical hooks are useEntityAudit + useGlobalAuditTrail. Forbidden: direct writes to entity_audit_trail, inline collection() queries on ENTITY_AUDIT_TRAIL, re-implementation of either hook, manual RealtimeService event lists like GLOBAL_AUDIT_WATCH_EVENTS/ENTITY_EVENT_MAP, or bypassing firestoreQueryService with raw onSnapshot on the collection.",
      "forbiddenPatterns": [
        "(addDoc|setDoc|updateDoc)\\s*\\([^)]*(entity_audit_trail|ENTITY_AUDIT_TRAIL)",
        "collection\\s*\\(\\s*(COLLECTIONS\\.ENTITY_AUDIT_TRAIL|['\"]entity_audit_trail['\"])",
        "(function\\s+useEntityAudit\\s*\\(|const\\s+useEntityAudit\\s*=)",
        "(function\\s+useGlobalAuditTrail\\s*\\(|const\\s+useGlobalAuditTrail\\s*=)",
        "(GLOBAL_AUDIT_WATCH_EVENTS|ENTITY_EVENT_MAP)\\s*="
      ],
      "allowlist": [
        "src/services/entity-audit.service.ts",
        "src/services/entity-audit-client.service.ts",
        "src/hooks/useEntityAudit.ts",
        "src/hooks/useGlobalAuditTrail.ts",
        "src/app/api/audit-trail/",
        "src/config/firestore-collections.ts"
      ]
    },
    "firestore-realtime": {
      "ssotFile": "src/services/firestore/firestore-query.service.ts",
      "description": "Firestore realtime subscriptions must go through one of the two canonical layers: (1) firestoreQueryService.subscribe/subscribeDoc/subscribeSubcollection (ADR-214) for tenant-aware tenant-filtered reads — PRIMARY path, (2) RealtimeService.subscribeToCollection/subscribeToDocument (ADR-195 Phase 8) for raw wrapping + event bus dispatch. Direct onSnapshot() calls from firebase/firestore are forbidden outside these layers. Legacy scattered callers are in the baseline and will ratchet down as they get migrated — preferred migration target is firestoreQueryService because it auto-injects companyId/tenantId filters.",
      "forbiddenPatterns": [
        "\\bonSnapshot\\s*\\("
      ],
      "allowlist": [
        "src/services/firestore/firestore-query.service.ts",
        "src/services/realtime/RealtimeService.ts",
        "src/services/realtime/hooks/"
      ]
    },
