#!/bin/bash
# ENTERPRISE PRE-COMMIT HOOK — Parallel Execution Engine (Google-level)
#
# Architecture:
#   Phase 0  (sync)     Windows reserved names, project rules
#   Phase 1  (parallel) All independent checks (3.5–3.25, 4, 10) — ~3-5x speedup
#   Phase 2  (sync)     Dead-code check with interactive prompt (3.22)
#   Phase 3  (sync)     Test runners (5, 5B)
#   Phase 4  (info)     Warnings + bookkeeping (ADR, bundle, license, commit-msg)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}🔍 Running pre-commit checks...${NC}"

# ─── Staged file sets (used by multiple checks) ───────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' | grep -v 'node_modules' | grep -v '\.d\.ts')
LOCALE_FILES=$(echo "$STAGED_FILES" | grep -E 'src/i18n/locales/(el|en)/.*\.json$')
TS_STAGED=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' | grep -v '__tests__' | grep -v '\.test\.' | grep -v '\.spec\.' | grep -v '\.d\.ts' | grep -v 'i18n/locales')

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 0: SYNC — Windows reserved filenames
# ═══════════════════════════════════════════════════════════════════════════════
RESERVED_PATTERN="^(con|prn|aux|nul|com[0-9]|lpt[0-9])(\.|$)"
BLOCKED_FILES=""
while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    filename=$(basename "$file")
    if echo "$filename" | grep -iE "$RESERVED_PATTERN" > /dev/null 2>&1; then
        BLOCKED_FILES="${BLOCKED_FILES}  ❌ ${file}\n"
    fi
done <<< "$STAGED_FILES"

if [[ -n "$BLOCKED_FILES" ]]; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  🚫 COMMIT BLOCKED - Windows Reserved Filenames Detected${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${YELLOW}The following files use Windows reserved names:${NC}"
    echo -e "$BLOCKED_FILES"
    echo -e "${YELLOW}Reserved names: CON, PRN, AUX, NUL, COM0-COM9, LPT0-LPT9${NC}"
    echo -e "${YELLOW}These names cause issues with Windows tools and ZIP utilities.${NC}"
    echo ""
    echo -e "To fix: ${GREEN}git reset HEAD <file>${NC} then ${GREEN}rm <file>${NC}"
    echo ""
    exit 1
fi

# ─── PHASE 0: SYNC — Project-specific rules ───────────────────────────────────
CUSTOM_SCRIPT="scripts/validate-project-rules.sh"
if [[ -f "$CUSTOM_SCRIPT" && -n "$TS_FILES" ]]; then
    echo -e "${YELLOW}🔍 Running project-specific checks...${NC}"
    CUSTOM_OUTPUT=$(bash "$CUSTOM_SCRIPT" $TS_FILES 2>&1)
    CUSTOM_EXIT=$?
    if [[ $CUSTOM_EXIT -ne 0 ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED - Project Rule Violations${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo "$CUSTOM_OUTPUT"
        echo ""
        exit 1
    fi
    echo -e "${GREEN}  ✅ Project rules passed${NC}"
fi

# ─── Precompute trigger variables for conditional checks ──────────────────────
NAV_TRIGGER_FILES=$(echo "$STAGED_FILES" | grep -E '(src/config/smart-navigation-factory\.ts|src/i18n/locales/(el|en)/navigation\.json)$' || true)
RULES_COVERAGE_TRIGGERS=$(echo "$STAGED_FILES" | grep -E '^firestore\.rules$|^tests/firestore-rules/' || true)
STORAGE_COVERAGE_TRIGGERS=$(echo "$STAGED_FILES" | grep -E '^storage\.rules$|^tests/storage-rules/' || true)
NOTIF_LOCALE_TRIGGERS=$(echo "$STAGED_FILES" | grep -E '^src/config/notification-keys\.ts$|^src/i18n/locales/(el|en)/.*\.json$' || true)
AUDIT_CATALOGS_TRIGGER=$(echo "$STAGED_FILES" | grep -E '(src/config/audit-value-catalogs\.ts|src/i18n/locales/(el|en)/.*\.json)' || true)
SRC_TS_FILES=$(echo "$STAGED_FILES" | grep -E '^src/.*\.(ts|tsx)$' || true)

# Firestore companyId: only files containing query() + where()
QUERY_FILES=""
for f in $TS_STAGED; do
    [[ -f "$f" ]] && grep -q "query(" "$f" 2>/dev/null && grep -q "where(" "$f" 2>/dev/null && QUERY_FILES="$QUERY_FILES $f"
done
QUERY_FILES="${QUERY_FILES# }"

# ═══════════════════════════════════════════════════════════════════════════════
# Parallel runner infrastructure
# ═══════════════════════════════════════════════════════════════════════════════
_PIDS=(); _OUTFILES=(); _NAMES=()

# Launch an external command as a background job, capturing output to a temp file.
_launch() {
    local name="$1"; shift
    local outfile
    outfile=$(mktemp)
    "$@" >"$outfile" 2>&1 &
    _PIDS+=($!)
    _OUTFILES+=("$outfile")
    _NAMES+=("$name")
}

# Wait for all background jobs. Print each captured output in launch order.
# Returns 1 if any job failed, 0 if all passed.
_await_all() {
    local FAILED=0
    for i in "${!_PIDS[@]}"; do
        wait "${_PIDS[$i]}"
        local code=$?
        [[ -s "${_OUTFILES[$i]}" ]] && cat "${_OUTFILES[$i]}"
        rm -f "${_OUTFILES[$i]}"
        [[ $code -ne 0 ]] && FAILED=1
    done
    return $FAILED
}

# ═══════════════════════════════════════════════════════════════════════════════
# Inline check functions (run as ( subshell ) — inherit all parent variables)
# ═══════════════════════════════════════════════════════════════════════════════

# CHECK 4: Google-style file size limits
_check_file_sizes() {
    get_max_lines() {
        local f="$1"
        echo "$f" | grep -qE '(\.config\.|\.d\.ts$|\.test\.|\.spec\.|\.stories\.|\.qa\.|/config/|/types/|/data/|/_registry/|/__tests__/|/docs/|/adrs/|^scripts/|/scripts/|/i18n/locales/|-definitions\.|-schema|-constants|enterprise-id\.service\.ts)' && echo 0 && return
        echo "$f" | grep -qE '\.(tsx)$' && echo "$f" | grep -qE '(/components/|/ui/)' && echo 500 && return
        echo "$f" | grep -qE '/use[A-Z][^/]*\.ts$' && echo 500 && return
        echo "$f" | grep -qE '\.service\.ts$' && echo 500 && return
        echo "$f" | grep -qE '/api/.*route\.ts$' && echo 300 && return
        echo 500
    }
    get_file_type() {
        local f="$1"
        echo "$f" | grep -qE '\.(tsx)$' && echo "$f" | grep -qE '(/components/|/ui/)' && echo "Component" && return
        echo "$f" | grep -qE '/use[A-Z][^/]*\.ts$' && echo "Hook" && return
        echo "$f" | grep -qE '\.service\.ts$' && echo "Service" && return
        echo "$f" | grep -qE '/api/.*route\.ts$' && echo "API Route" && return
        echo "General"
    }
    local OVERSIZED=""
    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        local MAX; MAX=$(get_max_lines "$file")
        [[ "$MAX" -eq 0 ]] && continue
        if [[ -f "$file" ]]; then
            local LC; LC=$(wc -l < "$file" | tr -d ' ')
            if [[ "$LC" -gt "$MAX" ]]; then
                local FT; FT=$(get_file_type "$file")
                OVERSIZED="${OVERSIZED}  ❌ ${file} (${LC}/${MAX} lines — ${FT})\n"
            fi
        fi
    done <<< "$TS_FILES"
    if [[ -n "$OVERSIZED" ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED - File Size Exceeds Type-Specific Limit${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo -e "${YELLOW}Limits: Component 500 | Hook 500 | Service 500 | API 300 | General 500${NC}"
        echo -e "$OVERSIZED"
        echo -e "${YELLOW}Fix: Split into smaller, focused modules (Single Responsibility).${NC}"
        echo -e "${YELLOW}Exempt: config/, types/, data/, tests, definitions, schemas, i18n${NC}"
        echo ""
        exit 1
    fi
    echo -e "${GREEN}  ✅ File sizes OK${NC}"
}

# CHECK 10: Secret scan (no credentials in code)
_check_secret_scan() {
    local SECRET_VIOLATIONS=""
    while IFS= read -r file; do
        [[ -z "$file" || ! -f "$file" ]] && continue
        echo "$file" | grep -qE '(\.png$|\.jpg$|\.ico$|\.woff|\.lock$|\.env\.example|\.env\.sample|node_modules)' && continue
        echo "$file" | grep -qE '^scripts/git-hooks/' && continue
        echo "$file" | grep -qE '^\.github/workflows/' && continue
        echo "$file" | grep -qE '^docs/architecture-review/' && continue
        local MATCHES
        MATCHES=$(grep -nE "(sk-[a-zA-Z0-9_-]{20,}|sk_live_[a-zA-Z0-9]{20,}|AIza[a-zA-Z0-9_-]{35}|ghp_[a-zA-Z0-9]{36}|xoxb-[a-zA-Z0-9-]+|AAAA[a-zA-Z0-9_-]{100,})" "$file" 2>/dev/null | grep -vE "^\s*(//|\*|#)" | head -3)
        [[ -n "$MATCHES" ]] && SECRET_VIOLATIONS="${SECRET_VIOLATIONS}  ❌ API key pattern in ${file}\n$(echo "$MATCHES" | sed 's/^/     /')\n"
        MATCHES=$(grep -nEi "(password|secret|private_key|api_key)\s*[:=]\s*['\"][^'\"]{8,}['\"]" "$file" 2>/dev/null | grep -vE "^\s*(//|\*|#)|\.env|process\.env|example|placeholder|schema|type|interface|dummy|test|mock" | head -3)
        [[ -n "$MATCHES" ]] && SECRET_VIOLATIONS="${SECRET_VIOLATIONS}  ❌ Hardcoded secret in ${file}\n$(echo "$MATCHES" | sed 's/^/     /')\n"
        MATCHES=$(grep -n "BEGIN.*PRIVATE KEY" "$file" 2>/dev/null | head -1)
        [[ -n "$MATCHES" ]] && SECRET_VIOLATIONS="${SECRET_VIOLATIONS}  ❌ Private key in ${file}\n"
    done <<< "$STAGED_FILES"
    if [[ -n "$SECRET_VIOLATIONS" ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED — Potential secrets detected${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo -e "$SECRET_VIOLATIONS"
        echo -e "${YELLOW}  Move secrets to .env files or environment variables.${NC}"
        echo -e "${YELLOW}  If false positive, add to .gitignore or refactor.${NC}"
        echo ""
        exit 1
    fi
    echo -e "${GREEN}  ✅ Secret scan: clean${NC}"
}

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 1: Launch all parallelizable checks
# ═══════════════════════════════════════════════════════════════════════════════

if [[ -n "$TS_FILES" ]]; then
    # CHECK 3.5: hardcoded i18n defaultValue (CLAUDE.md N.11)
    [[ -f "scripts/check-hardcoded-strings.sh" ]] && \
        _launch "3.5" bash "scripts/check-hardcoded-strings.sh" $TS_FILES

    # CHECK 3.6: hardcoded UI strings (JSX/attrs/errors/toasts)
    [[ -f "scripts/check-ui-hardcoded-strings.sh" ]] && \
        _launch "3.6" bash "scripts/check-ui-hardcoded-strings.sh" $TS_FILES

    # CHECK 3.7: SSoT import violations (centralized module ratchet)
    [[ -f "scripts/check-ssot-imports.js" ]] && \
        _launch "3.7" node "scripts/check-ssot-imports.js" $TS_FILES

    # CHECK 3.8: missing i18n keys (t('key') without locale entry) — typically slowest
    [[ -f "scripts/check-i18n-missing-keys.js" ]] && \
        _launch "3.8" node "scripts/check-i18n-missing-keys.js" $TS_FILES

    # CHECK 3.12: option-label i18n key integrity
    [[ -f "scripts/check-option-i18n-keys.js" ]] && \
        _launch "3.12" node "scripts/check-option-i18n-keys.js" $TS_FILES

    # CHECK 3.13: i18n runtime resolver reachability (ADR-279/280)
    [[ -f "scripts/check-i18n-resolver-reachability.js" ]] && \
        _launch "3.13" node "scripts/check-i18n-resolver-reachability.js" $TS_FILES

    # CHECK 3.23: native HTML tooltip ratchet (AST-based)
    [[ -z "${SKIP_NATIVE_TOOLTIP:-}" && -f "scripts/check-native-tooltip.js" ]] && \
        _launch "3.23" node "scripts/check-native-tooltip.js" $TS_FILES

    # CHECK 3.24: Tabs SSoT import ratchet (ADR-328)
    [[ -z "${SKIP_TABS_IMPORT:-}" && -f "scripts/check-tabs-import-ratchet.js" ]] && \
        _launch "3.24" node "scripts/check-tabs-import-ratchet.js" $TS_FILES

    # CHECK 3.25: no-navigation-flash ratchet (ADR-267/300)
    [[ -z "${SKIP_NO_FLASH:-}" && -f "scripts/check-no-flash-ratchet.js" ]] && \
        _launch "3.25" node "scripts/check-no-flash-ratchet.js" $TS_FILES

    # CHECK 4: file size limits (subshell — inherits $TS_FILES)
    _of=$(mktemp); (_check_file_sizes) >"$_of" 2>&1 &
    _PIDS+=($!); _OUTFILES+=("$_of"); _NAMES+=("4-file-sizes")
fi

# CHECK 3.9: ICU interpolation {{var}} → {var} (locale files only)
[[ -f "scripts/check-icu-interpolation.sh" && -n "$LOCALE_FILES" ]] && \
    _launch "3.9" bash "scripts/check-icu-interpolation.sh" $LOCALE_FILES

# CHECK 3.10: Firestore queries must include companyId
[[ -f "scripts/check-firestore-companyid.sh" && -n "$QUERY_FILES" ]] && \
    _launch "3.10" bash "scripts/check-firestore-companyid.sh" $QUERY_FILES

# CHECK 3.11: Navigation label completeness
[[ -f "scripts/check-navigation-labels.js" && -n "$NAV_TRIGGER_FILES" ]] && \
    _launch "3.11" node "scripts/check-navigation-labels.js"

# CHECK 3.14: Audit value catalogs parity (ADR-195)
[[ -f "scripts/check-audit-value-catalogs.js" && -n "$AUDIT_CATALOGS_TRIGGER" ]] && \
    _launch "3.14" node "scripts/check-audit-value-catalogs.js"

if [[ -n "$SRC_TS_FILES" ]]; then
    # CHECK 3.15: Firestore index coverage
    [[ -f "scripts/check-firestore-index-coverage.js" ]] && \
        _launch "3.15" node "scripts/check-firestore-index-coverage.js" $SRC_TS_FILES

    # CHECK 3.17: Entity audit coverage (ADR-195)
    [[ -f "scripts/check-entity-audit-coverage.js" ]] && \
        _launch "3.17" node "scripts/check-entity-audit-coverage.js" $SRC_TS_FILES

    # CHECK 3.18: SSoT Discover ratchet (ADR-314)
    if [[ -f "scripts/check-ssot-discover-ratchet.js" ]]; then
        if [[ "${SSOT_DISCOVER_FULL:-0}" == "1" ]]; then
            _launch "3.18" node "scripts/check-ssot-discover-ratchet.js" --full
        else
            _launch "3.18" node "scripts/check-ssot-discover-ratchet.js"
        fi
    fi

    # CHECK 3.20: Notification keys ratchet (SSoT Notifications)
    [[ -f "scripts/check-notification-keys-ratchet.js" ]] && \
        _launch "3.20" node "scripts/check-notification-keys-ratchet.js" $SRC_TS_FILES
fi

# CHECK 3.16: Firestore rules test coverage (ADR-298)
[[ -f "scripts/check-firestore-rules-test-coverage.js" && -n "$RULES_COVERAGE_TRIGGERS" ]] && \
    _launch "3.16" node "scripts/check-firestore-rules-test-coverage.js" $RULES_COVERAGE_TRIGGERS

# CHECK 3.19: Storage rules test coverage (ADR-301)
[[ -f "scripts/check-storage-rules-test-coverage.js" && -n "$STORAGE_COVERAGE_TRIGGERS" ]] && \
    _launch "3.19" node "scripts/check-storage-rules-test-coverage.js" $STORAGE_COVERAGE_TRIGGERS

# CHECK 3.21: Notification keys locale integrity
[[ -f "scripts/check-notification-keys-locale.js" && -n "$NOTIF_LOCALE_TRIGGERS" ]] && \
    _launch "3.21" node "scripts/check-notification-keys-locale.js"

# CHECK 10: Secret scan (subshell — inherits $STAGED_FILES)
_of=$(mktemp); (_check_secret_scan) >"$_of" 2>&1 &
_PIDS+=($!); _OUTFILES+=("$_of"); _NAMES+=("10-secrets")

# ─── Await all parallel jobs ──────────────────────────────────────────────────
_COUNT="${#_PIDS[@]}"
[[ $_COUNT -gt 0 ]] && echo -e "${YELLOW}⚡ ${_COUNT} checks running in parallel...${NC}"

if ! _await_all; then
    echo ""
    exit 1
fi

[[ $_COUNT -gt 0 ]] && echo -e "${GREEN}  ✅ All ${_COUNT} parallel checks passed${NC}"

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 2: SYNC — Dead-code ratchet (CHECK 3.22)
# Sequential because of interactive /dev/tty prompt.
# Skipped entirely if no .ts/.tsx staged (same as before).
# ═══════════════════════════════════════════════════════════════════════════════

if [[ -z "${SKIP_DEADCODE_CHECK:-}" ]] && [[ -n "$TS_FILES" ]] && [[ -f ".deadcode-baseline.json" ]]; then
    echo -e "${YELLOW}🔍 Checking dead-code ratchet (CHECK 3.22)...${NC}"

    # Part A: block staging modifications to files already in the dead-code baseline.
    BASELINE_FILES=$(node -e "
      const b = require('./.deadcode-baseline.json');
      console.log((b.files || []).join('\n'));
    " 2>/dev/null)

    STAGED_DEAD_FILES=""
    for f in $TS_FILES; do
        NORM=$(echo "$f" | sed 's|\\|/|g')
        if echo "$BASELINE_FILES" | grep -qxF "$NORM"; then
            STAGED_DEAD_FILES="${STAGED_DEAD_FILES}  ${NORM}\n"
        fi
    done

    if [[ -n "$STAGED_DEAD_FILES" ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED — CHECK 3.22: modifying known dead-code file(s)${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo -e "${YELLOW}  Staged file(s) that are unused (not imported anywhere):${NC}"
        printf "$STAGED_DEAD_FILES"
        echo ""

        ARCHIVE_CHOICE="n"
        echo -e "${YELLOW}  📦 Vuoi archiviare questi file in C:\\Nestor_Pagonis_Dead_Files? [y/N]${NC}"
        read -r ARCHIVE_CHOICE < /dev/tty 2>/dev/null || ARCHIVE_CHOICE="n"

        if [[ "$ARCHIVE_CHOICE" =~ ^[yY]$ ]]; then
            echo ""
            echo -e "${YELLOW}  Archiviazione in corso...${NC}"
            ARCHIVE_FAILED=0
            while IFS= read -r dead_file; do
                trimmed=$(echo "$dead_file" | xargs)
                [[ -z "$trimmed" ]] && continue
                if node scripts/archive-deadcode.js "$trimmed" 2>&1; then
                    :
                else
                    echo -e "${RED}  ⚠️  Archive fallito per: $trimmed${NC}"
                    ARCHIVE_FAILED=1
                fi
            done <<< "$(printf "$STAGED_DEAD_FILES" | sed 's/^  //')"

            if [[ $ARCHIVE_FAILED -eq 0 ]]; then
                echo ""
                echo -e "${GREEN}  ✅ Archive completato. Il commit rimane bloccato.${NC}"
            fi
            echo ""
        fi

        echo -e "${YELLOW}  Fix options:${NC}"
        echo -e "${YELLOW}    1. Import the file somewhere → re-run deadcode:baseline${NC}"
        echo -e "${YELLOW}    2. Delete it: npm run deadcode:delete -- <file>${NC}"
        echo -e "${YELLOW}  Emergency skip: SKIP_DEADCODE_CHECK=1 git commit ...${NC}"
        echo ""
        exit 1
    fi

    # Part B: block if new unused files appear beyond baseline.
    DEADCODE_OUTPUT=$(node scripts/check-deadcode-ratchet.js 2>&1)
    DEADCODE_EXIT=$?

    if [[ $DEADCODE_EXIT -ne 0 ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED — CHECK 3.22: new dead code introduced${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo "$DEADCODE_OUTPUT"
        echo ""
        echo -e "${YELLOW}  Fix: import or delete the listed file(s), then run:${NC}"
        echo -e "${YELLOW}    npm run deadcode:baseline${NC}"
        echo -e "${YELLOW}  Emergency skip: SKIP_DEADCODE_CHECK=1 git commit ...${NC}"
        echo ""
        exit 1
    fi

    echo -e "${GREEN}  $(echo "$DEADCODE_OUTPUT" | tail -1)${NC}"
fi

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 3: SYNC — Test runners (CHECK 5, 5B)
# Jest manages its own internal parallelism; running suites in parallel here
# would create resource contention — keep sequential.
# ═══════════════════════════════════════════════════════════════════════════════

# CHECK 5: AI Pipeline Tests
PIPELINE_FILES=$(echo "$STAGED_FILES" | grep -E '^src/services/ai-pipeline/' | grep -v '__tests__' | grep -v '.test.' || true)

if [[ -n "$PIPELINE_FILES" ]]; then
    echo -e "${YELLOW}🧪 AI Pipeline files changed — running test suite...${NC}"

    TEST_OUTPUT=$(npx jest --testPathPatterns="src/services/ai-pipeline" --silent 2>&1)
    TEST_EXIT=$?

    if [[ $TEST_EXIT -ne 0 ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED - AI Pipeline Tests Failed${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo "$TEST_OUTPUT" | tail -15
        echo ""
        echo -e "${YELLOW}Fix failing tests before committing pipeline changes.${NC}"
        echo -e "${YELLOW}Run: npm run test:ai-pipeline:all${NC}"
        echo ""
        exit 1
    fi

    PASS_INFO=$(echo "$TEST_OUTPUT" | grep -E "^Test Suites:" || echo "")
    echo -e "${GREEN}  ✅ AI Pipeline tests passed${NC} ${PASS_INFO:+— $PASS_INFO}"
fi

# CHECK 5B: Targeted Area Tests
run_area_tests() {
    local AREA_NAME="$1"
    local AREA_PATTERN="$2"
    local TEST_PATTERN="$3"
    local FIX_CMD="$4"

    local AREA_FILES
    AREA_FILES=$(echo "$STAGED_FILES" | grep -E "$AREA_PATTERN" | grep -v '__tests__' | grep -v '.test.' || true)

    if [[ -n "$AREA_FILES" ]]; then
        echo -e "${YELLOW}🧪 ${AREA_NAME} files changed — running tests...${NC}"

        local AREA_TEST_OUTPUT
        AREA_TEST_OUTPUT=$(npx jest --testPathPatterns="$TEST_PATTERN" --silent 2>&1)
        local AREA_TEST_EXIT=$?

        if [[ $AREA_TEST_EXIT -ne 0 ]]; then
            echo ""
            echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
            echo -e "${RED}  🚫 COMMIT BLOCKED - ${AREA_NAME} Tests Failed${NC}"
            echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
            echo ""
            echo "$AREA_TEST_OUTPUT" | tail -15
            echo ""
            echo -e "${YELLOW}Fix failing tests before committing.${NC}"
            echo -e "${YELLOW}Run: ${FIX_CMD}${NC}"
            echo ""
            exit 1
        fi

        local AREA_PASS_INFO
        AREA_PASS_INFO=$(echo "$AREA_TEST_OUTPUT" | grep -E "^Test Suites:" || echo "")
        echo -e "${GREEN}  ✅ ${AREA_NAME} tests passed${NC} ${AREA_PASS_INFO:+— $AREA_PASS_INFO}"
    fi
}

run_area_tests "Accounting" \
    "^src/subapps/accounting/" \
    "accounting" \
    "npx jest --testPathPatterns=accounting --verbose"

run_area_tests "Report Engine" \
