# =============================================================================
# CHECK 10: Secret Scan (Google — no credentials in code)
# =============================================================================
# Scans staged files for hardcoded secrets, API keys, passwords, tokens.
# BLOCKS commit — secrets in git history are a critical security risk.
# =============================================================================

SECRET_VIOLATIONS=""

while IFS= read -r file; do
    if [[ -z "$file" || ! -f "$file" ]]; then
        continue
    fi

    # Skip binary, config, lock, and env example files
    if echo "$file" | grep -qE '(\.png$|\.jpg$|\.ico$|\.woff|\.lock$|\.env\.example|\.env\.sample|node_modules)'; then
        continue
    fi

    # Skip the hooks directory itself — it contains literal regex strings
    # (e.g. "BEGIN.*PRIVATE KEY" as a grep pattern) that would self-trigger
    # the detectors below. The hook scripts are reviewed at commit time
    # anyway; they are not a realistic vector for leaked secrets.
    if echo "$file" | grep -qE '^scripts/git-hooks/'; then
        continue
    fi

    # Skip architecture-review docs — "risk-register-and-decisions" filename
    # triggers the sk-[...]{20,} OpenAI key pattern (false positive).
    if echo "$file" | grep -qE '^docs/architecture-review/'; then
        continue
    fi

    # Pattern 1: API keys (common formats — OpenAI, Google, GitHub, Slack, Firebase, Stripe)
    MATCHES=$(grep -nE "(sk-[a-zA-Z0-9_-]{20,}|sk_live_[a-zA-Z0-9]{20,}|AIza[a-zA-Z0-9_-]{35}|ghp_[a-zA-Z0-9]{36}|xoxb-[a-zA-Z0-9-]+|AAAA[a-zA-Z0-9_-]{100,})" "$file" 2>/dev/null | grep -vE "^\s*(//|\*|#)" | head -3)
    if [[ -n "$MATCHES" ]]; then
        SECRET_VIOLATIONS="${SECRET_VIOLATIONS}  ❌ API key pattern in ${file}\n"
        SECRET_VIOLATIONS="${SECRET_VIOLATIONS}$(echo "$MATCHES" | sed 's/^/     /')\n"
    fi

    # Pattern 2: Hardcoded passwords/secrets in assignments
    MATCHES=$(grep -nEi "(password|secret|private_key|api_key)\s*[:=]\s*['\"][^'\"]{8,}['\"]" "$file" 2>/dev/null | grep -vE "^\s*(//|\*|#)|\.env|process\.env|example|placeholder|schema|type|interface|dummy|test|mock" | head -3)
    if [[ -n "$MATCHES" ]]; then
        SECRET_VIOLATIONS="${SECRET_VIOLATIONS}  ❌ Hardcoded secret in ${file}\n"
        SECRET_VIOLATIONS="${SECRET_VIOLATIONS}$(echo "$MATCHES" | sed 's/^/     /')\n"
    fi

    # Pattern 3: Private keys
    MATCHES=$(grep -n "BEGIN.*PRIVATE KEY" "$file" 2>/dev/null | head -1)
    if [[ -n "$MATCHES" ]]; then
        SECRET_VIOLATIONS="${SECRET_VIOLATIONS}  ❌ Private key in ${file}\n"
    fi

done <<< "$STAGED_FILES"

if [[ -n "$SECRET_VIOLATIONS" ]]; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  🚫 COMMIT BLOCKED — Potential secrets detected${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "$SECRET_VIOLATIONS"
    echo -e "${YELLOW}  Move secrets to .env files or environment variables.${NC}"
    echo -e "${YELLOW}  If false positive, add to .gitignore or refactor.${NC}"
    echo ""
    exit 1
fi

echo -e "${GREEN}  ✅ Secret scan: clean${NC}"

# =============================================================================
# CHECK 11: Commit Message Format (Conventional Commits)
# =============================================================================
# Validates commit message follows: type(scope): description
# Types: fix, feat, refactor, docs, chore, test, perf, ci, style, build
# BLOCKS commit if format is wrong.
# NOTE: This runs via commit-msg hook, not pre-commit.
#       We install commit-msg hook here if it doesn't exist.
# =============================================================================

COMMIT_MSG_HOOK=".git/hooks/commit-msg"
if [[ ! -f "$COMMIT_MSG_HOOK" ]]; then
    cat > "$COMMIT_MSG_HOOK" << 'HOOK_EOF'
#!/bin/bash
# Conventional Commits validation (Google/Angular pattern)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE")

# Allow merge commits and reverts
if echo "$FIRST_LINE" | grep -qE "^(Merge|Revert) "; then
    exit 0
fi

# Conventional commit pattern: type(optional-scope): description
if ! echo "$FIRST_LINE" | grep -qE "^(fix|feat|refactor|docs|chore|test|perf|ci|style|build)(\([a-zA-Z0-9_-]+\))?: .{3,}"; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  🚫 COMMIT BLOCKED — Invalid commit message format${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${YELLOW}  Required: type(scope): description${NC}"
    echo -e "${YELLOW}  Types: fix, feat, refactor, docs, chore, test, perf, ci, style, build${NC}"
    echo -e "${YELLOW}  Example: fix(auth): resolve token expiration race condition${NC}"
    echo ""
    echo -e "  Your message: ${RED}${FIRST_LINE}${NC}"
    echo ""
    exit 1
fi

# Max length check (70 chars for first line)
if [[ ${#FIRST_LINE} -gt 100 ]]; then
    echo ""
    echo -e "${YELLOW}  ⚠️  Commit title is ${#FIRST_LINE} chars (recommended: <70, max: 100)${NC}"
    echo ""
fi

exit 0
HOOK_EOF
    chmod +x "$COMMIT_MSG_HOOK"
    echo -e "${GREEN}  ✅ Installed commit-msg hook (Conventional Commits)${NC}"
fi

# =============================================================================
# CHECK 12: License Compliance (CLAUDE.md N.5 — no GPL/AGPL)
# =============================================================================
# If package.json changed, scan for GPL/LGPL/AGPL dependencies.
# BLOCKS commit — GPL dependencies force open-source (Γιώργος wants proprietary).
# =============================================================================

PACKAGE_JSON_CHANGED=$(echo "$STAGED_FILES" | grep -E "^package\.json$" || true)

if [[ -n "$PACKAGE_JSON_CHANGED" ]]; then
    echo -e "${YELLOW}🔍 Checking dependency licenses (CLAUDE.md N.5)...${NC}"

    LICENSE_TMPFILE=$(mktemp)
    # Check licenses of all direct dependencies
    npx license-checker --direct --json --production 2>/dev/null > "$LICENSE_TMPFILE"
    LICENSE_EXIT=$?

    if [[ $LICENSE_EXIT -eq 0 && -s "$LICENSE_TMPFILE" ]]; then
        # Search for prohibited licenses
        GPL_DEPS=$(grep -B1 -iE '"(GPL|LGPL|AGPL)' "$LICENSE_TMPFILE" | grep -v "^\-\-$" | head -20)

        if [[ -n "$GPL_DEPS" ]]; then
            echo ""
            echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
            echo -e "${RED}  🚫 COMMIT BLOCKED — GPL/LGPL/AGPL dependency detected${NC}"
            echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
            echo ""
            echo "$GPL_DEPS"
            echo ""
            echo -e "${YELLOW}  Only MIT, Apache-2.0, BSD licenses allowed (CLAUDE.md N.5)${NC}"
            echo -e "${YELLOW}  Remove the dependency or find a permissive alternative.${NC}"
            echo ""
            rm -f "$LICENSE_TMPFILE"
            exit 1
        fi

        echo -e "${GREEN}  ✅ License compliance: all permissive${NC}"
    else
        echo -e "${YELLOW}  ⏭️  license-checker not available — skipped${NC}"
    fi
    rm -f "$LICENSE_TMPFILE"
fi

# =============================================================================
# CHECK 13: Bundle Size Guard (Google — prevent bundle bloat)
# =============================================================================
# If new imports added to staged files, warn about potential bundle impact.
# WARNING only — flags new large dependencies for awareness.
# Known heavy packages: moment, lodash (full), three.js, d3, pdf-lib
# =============================================================================

if [[ -n "$TS_FILES" ]]; then
    # Check for new imports of known heavy packages in staged diffs
    HEAVY_IMPORTS=$(git diff --cached -U0 -- $TS_FILES 2>/dev/null | grep "^+" | grep -v "^+++" | grep -E "from ['\"](moment|lodash['\"]|three|d3['\"]|chart\.js|pdf-lib|xlsx|exceljs|puppeteer|canvas|sharp)" | head -5)

    if [[ -n "$HEAVY_IMPORTS" ]]; then
        echo ""
        echo -e "${YELLOW}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${YELLOW}  ⚠️  Heavy dependency import detected — check bundle impact${NC}"
        echo -e "${YELLOW}═══════════════════════════════════════════════════════════════${NC}"
        echo "$HEAVY_IMPORTS" | sed 's/^+/  /'
        echo ""
        echo -e "${YELLOW}  Consider: tree-shakeable alternative, dynamic import(), or lazy loading.${NC}"
        echo -e "${YELLOW}  e.g.: import('lodash/get') instead of import _ from 'lodash'${NC}"
        echo ""
    fi
fi

# =============================================================================
# CHECK 3.22: Dead Code Ratchet (knip / 2026-04-24)
# =============================================================================
# Blocks commit if new unused files appear beyond .deadcode-baseline.json.
# Runs only when .ts/.tsx files are staged (skip on config-only changes).
# Skip: SKIP_DEADCODE_CHECK=1 git commit (emergency escape hatch).
# Baseline: .deadcode-baseline.json — update with: npm run deadcode:baseline
# =============================================================================

if [[ -z "${SKIP_DEADCODE_CHECK:-}" ]] && [[ -n "$TS_FILES" ]] && [[ -f ".deadcode-baseline.json" ]]; then
    echo -e "${YELLOW}🔍 Checking dead-code ratchet (CHECK 3.22)...${NC}"

    # Part A: block staging modifications to files already in the dead-code baseline.
    # Rationale: touching a dead file without importing it first = wasted work.
    # Fix: either import the file (removes it from baseline) or delete it entirely.
    BASELINE_FILES=$(node -e "
      const b = require('./.deadcode-baseline.json');
      console.log((b.files || []).join('\n'));
    " 2>/dev/null)

    STAGED_DEAD_FILES=""
    for f in $TS_FILES; do
        # Normalise to forward-slash relative path (knip uses forward slashes)
        NORM=$(echo "$f" | sed 's|\\|/|g')
        if echo "$BASELINE_FILES" | grep -qxF "$NORM"; then
            STAGED_DEAD_FILES="${STAGED_DEAD_FILES}  ${NORM}\n"
        fi
    done

    if [[ -n "$STAGED_DEAD_FILES" ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED — CHECK 3.22: modifying known dead-code file(s)${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo -e "${YELLOW}  Staged file(s) that are unused (not imported anywhere):${NC}"
        printf "$STAGED_DEAD_FILES"
        echo ""

        # Interactive archive prompt — ask before blocking.
        # Read from /dev/tty (terminal) so it works even when git pipes stdin.
        ARCHIVE_CHOICE="n"
        echo -e "${YELLOW}  📦 Vuoi archiviare questi file in C:\\Nestor_Pagonis_Dead_Files? [y/N]${NC}"
        read -r ARCHIVE_CHOICE < /dev/tty 2>/dev/null || ARCHIVE_CHOICE="n"

        if [[ "$ARCHIVE_CHOICE" =~ ^[yY]$ ]]; then
            echo ""
            echo -e "${YELLOW}  Archiviazione in corso...${NC}"
            ARCHIVE_FAILED=0
            while IFS= read -r dead_file; do
                trimmed=$(echo "$dead_file" | xargs)
                [[ -z "$trimmed" ]] && continue
                if node scripts/archive-deadcode.js "$trimmed" 2>&1; then
                    :
                else
                    echo -e "${RED}  ⚠️  Archive fallito per: $trimmed${NC}"
                    ARCHIVE_FAILED=1
                fi
            done <<< "$(printf "$STAGED_DEAD_FILES" | sed 's/^  //')"

            if [[ $ARCHIVE_FAILED -eq 0 ]]; then
                echo ""
                echo -e "${GREEN}  ✅ Archive completato. Il commit rimane bloccato.${NC}"
            fi
            echo ""
        fi

        echo -e "${YELLOW}  Fix options:${NC}"
        echo -e "${YELLOW}    1. Import the file somewhere → re-run deadcode:baseline${NC}"
        echo -e "${YELLOW}    2. Delete it: npm run deadcode:delete -- <file>${NC}"
        echo -e "${YELLOW}  Emergency skip: SKIP_DEADCODE_CHECK=1 git commit ...${NC}"
        echo ""
        exit 1
    fi

    # Part B: block if new unused files appear beyond baseline.
    DEADCODE_OUTPUT=$(node scripts/check-deadcode-ratchet.js 2>&1)
    DEADCODE_EXIT=$?

    if [[ $DEADCODE_EXIT -ne 0 ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED — CHECK 3.22: new dead code introduced${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo "$DEADCODE_OUTPUT"
        echo ""
        echo -e "${YELLOW}  Fix: import or delete the listed file(s), then run:${NC}"
        echo -e "${YELLOW}    npm run deadcode:baseline${NC}"
        echo -e "${YELLOW}  Emergency skip: SKIP_DEADCODE_CHECK=1 git commit ...${NC}"
        echo ""
        exit 1
    fi

    echo -e "${GREEN}  $(echo "$DEADCODE_OUTPUT" | tail -1)${NC}"
fi

echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
exit 0
