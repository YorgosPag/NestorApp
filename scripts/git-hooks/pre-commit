#!/bin/bash
# ENTERPRISE PRE-COMMIT HOOK — Node.js Worker Threads Engine (Google-level)
#
# Architecture:
#   Phase 0  (sync bash)  Windows reserved names, project rules
#   Phase 1  (node)       All independent checks via worker_threads
#                         → 1 node process, zero spawn overhead, shared OS file cache
#   Phase 2  (sync bash)  Dead-code check (interactive /dev/tty prompt)
#   Phase 3  (sync bash)  Test runners (jest manages its own parallelism)
#   Phase 4  (sync bash)  Warnings + bookkeeping (non-blocking)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}🔍 Running pre-commit checks...${NC}"

# ─── Staged file sets ─────────────────────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' | grep -v 'node_modules' | grep -v '\.d\.ts')
LOCALE_FILES=$(echo "$STAGED_FILES" | grep -E 'src/i18n/locales/(el|en)/.*\.json$')
TS_STAGED=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' | grep -v '__tests__' | grep -v '\.test\.' | grep -v '\.spec\.' | grep -v '\.d\.ts' | grep -v 'i18n/locales')

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 0: SYNC — Windows reserved filenames
# ═══════════════════════════════════════════════════════════════════════════════
RESERVED_PATTERN="^(con|prn|aux|nul|com[0-9]|lpt[0-9])(\.|$)"
BLOCKED_FILES=""
while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    filename=$(basename "$file")
    if echo "$filename" | grep -iE "$RESERVED_PATTERN" > /dev/null 2>&1; then
        BLOCKED_FILES="${BLOCKED_FILES}  ❌ ${file}\n"
    fi
done <<< "$STAGED_FILES"

if [[ -n "$BLOCKED_FILES" ]]; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  🚫 COMMIT BLOCKED - Windows Reserved Filenames Detected${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${YELLOW}The following files use Windows reserved names:${NC}"
    echo -e "$BLOCKED_FILES"
    echo -e "${YELLOW}Reserved names: CON, PRN, AUX, NUL, COM0-COM9, LPT0-LPT9${NC}"
    echo -e "${YELLOW}These names cause issues with Windows tools and ZIP utilities.${NC}"
    echo ""
    echo -e "To fix: ${GREEN}git reset HEAD <file>${NC} then ${GREEN}rm <file>${NC}"
    echo ""
    exit 1
fi

# ─── PHASE 0: SYNC — Project-specific rules ───────────────────────────────────
CUSTOM_SCRIPT="scripts/validate-project-rules.sh"
if [[ -f "$CUSTOM_SCRIPT" && -n "$TS_FILES" ]]; then
    echo -e "${YELLOW}🔍 Running project-specific checks...${NC}"
    CUSTOM_OUTPUT=$(bash "$CUSTOM_SCRIPT" $TS_FILES 2>&1)
    CUSTOM_EXIT=$?
    if [[ $CUSTOM_EXIT -ne 0 ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED - Project Rule Violations${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo "$CUSTOM_OUTPUT"
        echo ""
        exit 1
    fi
    echo -e "${GREEN}  ✅ Project rules passed${NC}"
fi

# ─── Precompute trigger variables ─────────────────────────────────────────────
NAV_TRIGGER_FILES=$(echo "$STAGED_FILES" | grep -E '(src/config/smart-navigation-factory\.ts|src/i18n/locales/(el|en)/navigation\.json)$' || true)
RULES_COVERAGE_TRIGGERS=$(echo "$STAGED_FILES" | grep -E '^firestore\.rules$|^tests/firestore-rules/' || true)
STORAGE_COVERAGE_TRIGGERS=$(echo "$STAGED_FILES" | grep -E '^storage\.rules$|^tests/storage-rules/' || true)
NOTIF_LOCALE_TRIGGERS=$(echo "$STAGED_FILES" | grep -E '^src/config/notification-keys\.ts$|^src/i18n/locales/(el|en)/.*\.json$' || true)
AUDIT_CATALOGS_TRIGGER=$(echo "$STAGED_FILES" | grep -E '(src/config/audit-value-catalogs\.ts|src/i18n/locales/(el|en)/.*\.json)' || true)
SRC_TS_FILES=$(echo "$STAGED_FILES" | grep -E '^src/.*\.(ts|tsx)$' || true)

# Firestore companyId: only files containing both query() and where()
QUERY_FILES=""
for f in $TS_STAGED; do
    [[ -f "$f" ]] && grep -q "query(" "$f" 2>/dev/null && grep -q "where(" "$f" 2>/dev/null && QUERY_FILES="$QUERY_FILES
$f"
done
QUERY_FILES=$(echo "$QUERY_FILES" | grep -v '^$' || true)

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 1: Node.js worker_threads orchestrator
# — one node process, all checks run in parallel threads (JS) or processes (.sh)
# ═══════════════════════════════════════════════════════════════════════════════

export STAGED_TS_FILES="$TS_FILES"
export STAGED_LOCALE_FILES="$LOCALE_FILES"
export STAGED_QUERY_FILES="$QUERY_FILES"
export STAGED_SRC_TS_FILES="$SRC_TS_FILES"
export STAGED_ALL_FILES="$STAGED_FILES"
export STAGED_NAV_TRIGGER_FILES="$NAV_TRIGGER_FILES"
export STAGED_RULES_COVERAGE_TRIGGERS="$RULES_COVERAGE_TRIGGERS"
export STAGED_STORAGE_COVERAGE_TRIGGERS="$STORAGE_COVERAGE_TRIGGERS"
export STAGED_NOTIF_LOCALE_TRIGGERS="$NOTIF_LOCALE_TRIGGERS"
export STAGED_AUDIT_CATALOGS_TRIGGER="$AUDIT_CATALOGS_TRIGGER"
# Pass through any existing env overrides (SSOT_DISCOVER_FULL, SKIP_*, etc.)

node scripts/run-checks-parallel.js
PHASE1_EXIT=$?

if [[ $PHASE1_EXIT -ne 0 ]]; then
    echo ""
    exit 1
fi

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 2: SYNC — Dead-code ratchet (CHECK 3.22)
# Sequential because of interactive /dev/tty prompt.
# ═══════════════════════════════════════════════════════════════════════════════

if [[ -z "${SKIP_DEADCODE_CHECK:-}" ]] && [[ -n "$TS_FILES" ]] && [[ -f ".deadcode-baseline.json" ]]; then
    echo -e "${YELLOW}🔍 Checking dead-code ratchet (CHECK 3.22)...${NC}"

    BASELINE_FILES=$(node -e "
      const b = require('./.deadcode-baseline.json');
      console.log((b.files || []).join('\n'));
    " 2>/dev/null)

    STAGED_DEAD_FILES=""
    for f in $TS_FILES; do
        NORM=$(echo "$f" | sed 's|\\|/|g')
        if echo "$BASELINE_FILES" | grep -qxF "$NORM"; then
            STAGED_DEAD_FILES="${STAGED_DEAD_FILES}  ${NORM}\n"
        fi
    done

    if [[ -n "$STAGED_DEAD_FILES" ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED — CHECK 3.22: modifying known dead-code file(s)${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo -e "${YELLOW}  Staged file(s) that are unused (not imported anywhere):${NC}"
        printf "$STAGED_DEAD_FILES"
        echo ""

        ARCHIVE_CHOICE="n"
        echo -e "${YELLOW}  📦 Vuoi archiviare questi file in C:\\Nestor_Pagonis_Dead_Files? [y/N]${NC}"
        read -r ARCHIVE_CHOICE < /dev/tty 2>/dev/null || ARCHIVE_CHOICE="n"

        if [[ "$ARCHIVE_CHOICE" =~ ^[yY]$ ]]; then
            echo ""
            echo -e "${YELLOW}  Archiviazione in corso...${NC}"
            ARCHIVE_FAILED=0
            while IFS= read -r dead_file; do
                trimmed=$(echo "$dead_file" | xargs)
                [[ -z "$trimmed" ]] && continue
                if node scripts/archive-deadcode.js "$trimmed" 2>&1; then
                    :
                else
                    echo -e "${RED}  ⚠️  Archive fallito per: $trimmed${NC}"
                    ARCHIVE_FAILED=1
                fi
            done <<< "$(printf "$STAGED_DEAD_FILES" | sed 's/^  //')"

            if [[ $ARCHIVE_FAILED -eq 0 ]]; then
                echo ""
                echo -e "${GREEN}  ✅ Archive completato. Il commit rimane bloccato.${NC}"
            fi
            echo ""
        fi

        echo -e "${YELLOW}  Fix options:${NC}"
        echo -e "${YELLOW}    1. Import the file somewhere → re-run deadcode:baseline${NC}"
        echo -e "${YELLOW}    2. Delete it: npm run deadcode:delete -- <file>${NC}"
        echo -e "${YELLOW}  Emergency skip: SKIP_DEADCODE_CHECK=1 git commit ...${NC}"
        echo ""
        exit 1
    fi

    DEADCODE_OUTPUT=$(node scripts/check-deadcode-ratchet.js 2>&1)
    DEADCODE_EXIT=$?

    if [[ $DEADCODE_EXIT -ne 0 ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED — CHECK 3.22: new dead code introduced${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo "$DEADCODE_OUTPUT"
        echo ""
        echo -e "${YELLOW}  Fix: import or delete the listed file(s), then run:${NC}"
        echo -e "${YELLOW}    npm run deadcode:baseline${NC}"
        echo -e "${YELLOW}  Emergency skip: SKIP_DEADCODE_CHECK=1 git commit ...${NC}"
        echo ""
        exit 1
    fi

    echo -e "${GREEN}  $(echo "$DEADCODE_OUTPUT" | tail -1)${NC}"
fi

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 3: SYNC — Test runners (CHECK 5, 5B)
# Jest manages its own internal parallelism — keep sequential.
# ═══════════════════════════════════════════════════════════════════════════════

# CHECK 5: AI Pipeline Tests
PIPELINE_FILES=$(echo "$STAGED_FILES" | grep -E '^src/services/ai-pipeline/' | grep -v '__tests__' | grep -v '.test.' || true)

if [[ -n "$PIPELINE_FILES" ]]; then
    echo -e "${YELLOW}🧪 AI Pipeline files changed — running test suite...${NC}"

    TEST_OUTPUT=$(npx jest --testPathPatterns="src/services/ai-pipeline" --silent 2>&1)
    TEST_EXIT=$?

    if [[ $TEST_EXIT -ne 0 ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED - AI Pipeline Tests Failed${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo "$TEST_OUTPUT" | tail -15
        echo ""
        echo -e "${YELLOW}Fix failing tests before committing pipeline changes.${NC}"
        echo -e "${YELLOW}Run: npm run test:ai-pipeline:all${NC}"
        echo ""
        exit 1
    fi

    PASS_INFO=$(echo "$TEST_OUTPUT" | grep -E "^Test Suites:" || echo "")
    echo -e "${GREEN}  ✅ AI Pipeline tests passed${NC} ${PASS_INFO:+— $PASS_INFO}"
fi

# CHECK 5B: Targeted Area Tests
run_area_tests() {
    local AREA_NAME="$1"
    local AREA_PATTERN="$2"
    local TEST_PATTERN="$3"
    local FIX_CMD="$4"

    local AREA_FILES
    AREA_FILES=$(echo "$STAGED_FILES" | grep -E "$AREA_PATTERN" | grep -v '__tests__' | grep -v '.test.' || true)

    if [[ -n "$AREA_FILES" ]]; then
        echo -e "${YELLOW}🧪 ${AREA_NAME} files changed — running tests...${NC}"

        local AREA_TEST_OUTPUT
        AREA_TEST_OUTPUT=$(npx jest --testPathPatterns="$TEST_PATTERN" --silent 2>&1)
        local AREA_TEST_EXIT=$?

        if [[ $AREA_TEST_EXIT -ne 0 ]]; then
            echo ""
            echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
            echo -e "${RED}  🚫 COMMIT BLOCKED - ${AREA_NAME} Tests Failed${NC}"
            echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
            echo ""
            echo "$AREA_TEST_OUTPUT" | tail -15
            echo ""
            echo -e "${YELLOW}Fix failing tests before committing.${NC}"
            echo -e "${YELLOW}Run: ${FIX_CMD}${NC}"
            echo ""
            exit 1
        fi

        local AREA_PASS_INFO
        AREA_PASS_INFO=$(echo "$AREA_TEST_OUTPUT" | grep -E "^Test Suites:" || echo "")
        echo -e "${GREEN}  ✅ ${AREA_NAME} tests passed${NC} ${AREA_PASS_INFO:+— $AREA_PASS_INFO}"
    fi
}

run_area_tests "Accounting" \
    "^src/subapps/accounting/" \
    "accounting" \
    "npx jest --testPathPatterns=accounting --verbose"

run_area_tests "Report Engine" \
    "^src/services/report-engine/" \
    "report-engine" \
    "npx jest --testPathPatterns=report-engine --verbose"

run_area_tests "Entity Linking" \
    "^src/services/entity-linking/" \
    "entity-linking" \
    "npx jest --testPathPatterns=entity-linking --verbose"

run_area_tests "DXF Geometry" \
    "^src/subapps/dxf-viewer/rendering/entities/shared/" \
    "geometry.*utils" \
    "npx jest --testPathPatterns='geometry.*utils' --verbose"

run_area_tests "Type Safety" \
    "^src/types/" \
    "src/types/__tests__" \
    "npx jest --testPathPatterns='src/types/__tests__' --verbose"

run_area_tests "Contact Mutations" \
    "^src/(utils/contactForm|hooks/.*[Cc]ontact|services/contacts)" \
    "contact-mutation" \
    "npx jest --testPathPatterns=contact-mutation --verbose"

run_area_tests "Contact Mappers" \
    "^src/utils/contactForm/(contactMapper\.ts|fieldMappers/)" \
    "src/utils/contactForm/__tests__/contactMapper" \
    "npm run test:contact-mappers"

run_area_tests "Contact Sanitize" \
    "^src/utils/contactForm/utils/data-cleaning\.ts|^src/services/contacts\.service\.ts" \
    "src/utils/contactForm/utils/__tests__/data-cleaning" \
    "npm run test:contact-sanitize"

run_area_tests "Clearable Select" \
    "^src/components/generic/form-select-helpers\.tsx|^src/components/generic/(Individual|Generic|Service)FormRenderer\.tsx" \
    "src/components/generic/__tests__/form-select-helpers" \
    "npm run test:clearable-select"

run_area_tests "ESCO Pickers" \
    "^src/components/shared/esco/|^src/components/shared/Esco(Occupation|Skill)Picker\.tsx" \
    "src/components/shared/esco/__tests__/esco-picker-popover-shell" \
    "npm run test:esco-pickers"

run_area_tests "File Display Cascade" \
    "^src/(services/filesystem|services/property|app/api/files/propagate|components/shared/files/hooks/useEntityFiles)" \
    "file-mutation-gateway-propagate|property-mutation-gateway|entity-file-display-propagator|propagate-entity-rename|useEntityFiles-realtime" \
    "npx jest --testPathPatterns='file-mutation-gateway-propagate|property-mutation-gateway|entity-file-display-propagator|propagate-entity-rename|useEntityFiles-realtime' --verbose"

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 4: INFO — Non-blocking warnings + bookkeeping
# ═══════════════════════════════════════════════════════════════════════════════

# CHECK 6: ADR Documentation Reminder (warning only — does not block)
SRC_CODE_FILES=$(echo "$STAGED_FILES" | grep -E '^src/' | grep -E '\.(ts|tsx)$' | grep -v '\.test\.' | grep -v '\.spec\.' | grep -v '__tests__' | grep -v '/i18n/locales/' || true)
DOC_FILES=$(echo "$STAGED_FILES" | grep -E '\.(md)$' | grep -E '(^docs/|^adrs/|ADR-)' || true)

if [[ -n "$SRC_CODE_FILES" && -z "$DOC_FILES" ]]; then
    SRC_COUNT=$(echo "$SRC_CODE_FILES" | wc -l | tr -d ' ')
    if [[ "$SRC_COUNT" -ge 3 ]]; then
        echo ""
        echo -e "${YELLOW}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${YELLOW}  ⚠️  ADR REMINDER — ${SRC_COUNT} src/ files changed, 0 ADR docs staged${NC}"
        echo -e "${YELLOW}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${YELLOW}  Google Pattern: Code + Documentation = same commit.${NC}"
        echo -e "${YELLOW}  Check: docs/centralized-systems/reference/adrs/${NC}"
        echo -e "${YELLOW}  Ignore if no ADR applies to this change.${NC}"
        echo ""
    fi
fi

# CHECK 6C: ADR-040 RATCHET — Orchestrator useSyncExternalStore prohibition (BLOCKING)
# CanvasSection.tsx and CanvasLayerStack.tsx MUST NOT call useSyncExternalStore directly.
# All high-frequency store subscriptions must live in micro-leaf components only.
# Violation = 60fps re-render of the full canvas subtree (guide drag, hover, marquee regression).
ORCHESTRATOR_STAGED=$(echo "$STAGED_FILES" | grep -E \
  'src/subapps/dxf-viewer/components/dxf-layout/(CanvasSection|CanvasLayerStack)\.tsx' \
  || true)

if [[ -n "$ORCHESTRATOR_STAGED" ]]; then
  ORCH_VIOLATION=""
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    if grep -qE "useSyncExternalStore\(" "$file" 2>/dev/null; then
      ORCH_VIOLATION="${ORCH_VIOLATION}  ❌ ${file}\n"
    fi
  done <<< "$ORCHESTRATOR_STAGED"

  if [[ -n "$ORCH_VIOLATION" ]]; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  🚫 COMMIT BLOCKED — ADR-040 Orchestrator Subscription Violation${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${RED}  CanvasSection.tsx / CanvasLayerStack.tsx MUST NOT call${NC}"
    echo -e "${RED}  useSyncExternalStore. Push subscriptions to micro-leaves:${NC}"
    echo -e "${RED}    → canvas-layer-stack-leaves.tsx (DxfCanvasSubscriber, DraftLayerSubscriber)${NC}"
    echo ""
    echo -e "${YELLOW}  Files with violation:${NC}"
    echo -e "$ORCH_VIOLATION"
    echo -e "${YELLOW}  Reference: ADR-040 Phase II — micro-leaf subscriber pattern${NC}"
    echo -e "${YELLOW}  docs/centralized-systems/reference/adrs/ADR-040-preview-canvas-performance.md${NC}"
    echo ""
    exit 1
  fi
fi

# CHECK 6B: DXF Viewer performance-critical files → ADR-040 reminder (warning only)
# These files implement the micro-leaf subscriber architecture (Phase E, ADR-040).
# Any change to them should be documented in the ADR changelog.
DXF_PERF_CRITICAL_FILES=$(echo "$STAGED_FILES" | grep -E \
  'src/subapps/dxf-viewer/(components/dxf-layout/(CanvasSection|CanvasLayerStack|canvas-layer-stack-leaves|canvas-layer-stack-types)|canvas-v2/dxf-canvas/(DxfRenderer|dxf-canvas-renderer|dxf-bitmap-cache)|hooks/(state/useGuideActions|state/useGuideState|canvas/guide-click-handlers|canvas/useCanvasContextMenu|canvas/canvas-click-types)|systems/(hover/HoverStore|cursor/ImmediatePositionStore|cursor/ImmediateSnapStore)|rendering/core/UnifiedFrameScheduler)' \
  || true)
ADR040_STAGED=$(echo "$STAGED_FILES" | grep -i "ADR-040" || true)

if [[ -n "$DXF_PERF_CRITICAL_FILES" && -z "$ADR040_STAGED" ]]; then
    DXF_COUNT=$(echo "$DXF_PERF_CRITICAL_FILES" | grep -c . || echo 0)
    echo ""
    echo -e "${YELLOW}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${YELLOW}  ⚠️  DXF PERF ARCHITECTURE — ${DXF_COUNT} critical file(s) modified, ADR-040 not staged${NC}"
    echo -e "${YELLOW}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${YELLOW}  Files touched:${NC}"
    echo "$DXF_PERF_CRITICAL_FILES" | while read -r f; do echo -e "${YELLOW}    • $f${NC}"; done
    echo ""
    echo -e "${YELLOW}  These files implement the micro-leaf subscriber pattern (ADR-040).${NC}"
    echo -e "${YELLOW}  If your change is architectural, update the changelog:${NC}"
    echo -e "${YELLOW}    docs/centralized-systems/reference/adrs/ADR-040-preview-canvas-performance.md${NC}"
    echo -e "${YELLOW}  Skip if this is a trivial fix (typo, rename, etc.).${NC}"
    echo ""
fi

# CHECK 11: Install commit-msg hook (Conventional Commits) if missing
COMMIT_MSG_HOOK=".git/hooks/commit-msg"
if [[ ! -f "$COMMIT_MSG_HOOK" ]]; then
    cat > "$COMMIT_MSG_HOOK" << 'HOOK_EOF'
#!/bin/bash
# Conventional Commits validation (Google/Angular pattern)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

COMMIT_MSG_FILE="$1"
FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE")

# Allow merge commits and reverts
if echo "$FIRST_LINE" | grep -qE "^(Merge|Revert) "; then
    exit 0
fi

# Conventional commit pattern: type(optional-scope): description
if ! echo "$FIRST_LINE" | grep -qE "^(fix|feat|refactor|docs|chore|test|perf|ci|style|build)(\([a-zA-Z0-9_-]+\))?: .{3,}"; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  🚫 COMMIT BLOCKED — Invalid commit message format${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${YELLOW}  Required: type(scope): description${NC}"
    echo -e "${YELLOW}  Types: fix, feat, refactor, docs, chore, test, perf, ci, style, build${NC}"
    echo -e "${YELLOW}  Example: fix(auth): resolve token expiration race condition${NC}"
    echo ""
    echo -e "  Your message: ${RED}${FIRST_LINE}${NC}"
    echo ""
    exit 1
fi

if [[ ${#FIRST_LINE} -gt 100 ]]; then
    echo ""
    echo -e "${YELLOW}  ⚠️  Commit title is ${#FIRST_LINE} chars (recommended: <70, max: 100)${NC}"
    echo ""
fi

exit 0
HOOK_EOF
    chmod +x "$COMMIT_MSG_HOOK"
    echo -e "${GREEN}  ✅ Installed commit-msg hook (Conventional Commits)${NC}"
fi

# CHECK 12: License Compliance (CLAUDE.md N.5 — no GPL/AGPL)
PACKAGE_JSON_CHANGED=$(echo "$STAGED_FILES" | grep -E "^package\.json$" || true)

if [[ -n "$PACKAGE_JSON_CHANGED" ]]; then
    echo -e "${YELLOW}🔍 Checking dependency licenses (CLAUDE.md N.5)...${NC}"

    LICENSE_TMPFILE=$(mktemp)
    npx license-checker --direct --json --production 2>/dev/null > "$LICENSE_TMPFILE"
    LICENSE_EXIT=$?

    if [[ $LICENSE_EXIT -eq 0 && -s "$LICENSE_TMPFILE" ]]; then
        GPL_DEPS=$(grep -B1 -iE '"(GPL|LGPL|AGPL)' "$LICENSE_TMPFILE" | grep -v "^\-\-$" | head -20)

        if [[ -n "$GPL_DEPS" ]]; then
            echo ""
            echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
            echo -e "${RED}  🚫 COMMIT BLOCKED — GPL/LGPL/AGPL dependency detected${NC}"
            echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
            echo ""
            echo "$GPL_DEPS"
            echo ""
            echo -e "${YELLOW}  Only MIT, Apache-2.0, BSD licenses allowed (CLAUDE.md N.5)${NC}"
            echo -e "${YELLOW}  Remove the dependency or find a permissive alternative.${NC}"
            echo ""
            rm -f "$LICENSE_TMPFILE"
            exit 1
        fi

        echo -e "${GREEN}  ✅ License compliance: all permissive${NC}"
    else
        echo -e "${YELLOW}  ⏭️  license-checker not available — skipped${NC}"
    fi
    rm -f "$LICENSE_TMPFILE"
fi

# CHECK 13: Bundle Size Guard — warning only
if [[ -n "$TS_FILES" ]]; then
    HEAVY_IMPORTS=$(git diff --cached -U0 -- $TS_FILES 2>/dev/null | grep "^+" | grep -v "^+++" | grep -E "from ['\"](moment|lodash['\"]|three|d3['\"]|chart\.js|pdf-lib|xlsx|exceljs|puppeteer|canvas|sharp)" | head -5)

    if [[ -n "$HEAVY_IMPORTS" ]]; then
        echo ""
        echo -e "${YELLOW}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${YELLOW}  ⚠️  Heavy dependency import detected — check bundle impact${NC}"
        echo -e "${YELLOW}═══════════════════════════════════════════════════════════════${NC}"
        echo "$HEAVY_IMPORTS" | sed 's/^+/  /'
        echo ""
        echo -e "${YELLOW}  Consider: tree-shakeable alternative, dynamic import(), or lazy loading.${NC}"
        echo ""
    fi
fi

echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
exit 0
