# =============================================================================
# CHECK 4: Google-Style File Size Limits (per file type)
# =============================================================================
# Limits based on Single Responsibility Principle:
#   Component (.tsx in components/)  → 500 lines (CLAUDE.md N.7.1)
#   Hook (use*.ts)                   → 500 lines (CLAUDE.md N.7.1)
#   Service (.service.ts)            → 500 lines (CLAUDE.md N.7.1)
#   API Route (route.ts in api/)     → 300 lines (1 endpoint handler)
#   General .ts/.tsx                 → 500 lines (CLAUDE.md N.7.1)
#
# EXEMPT (no limit):
#   config/, types/, data/, *.config.*, *.d.ts, *.test.*, *.spec.*,
#   *-definitions.ts, *-schema*.ts, *.stories.*, i18n/locales/,
#   __tests__/, docs/, adrs/, scripts/
# =============================================================================

if [[ -n "$TS_FILES" ]]; then
    echo -e "${YELLOW}🔍 Checking file sizes (Google-style per-type limits)...${NC}"

    OVERSIZED_FILES=""

    # Determine max lines based on file type
    get_max_lines() {
        local file="$1"

        # EXEMPT patterns — no limit
        # /_registry/ added 2026-04-13: firestore-rules _registry is a pure typed data registry
        # (coverage-manifest.ts, coverage-matrices*.ts) — no business logic, data-file semantics.
        if echo "$file" | grep -qE '(\.config\.|\.d\.ts$|\.test\.|\.spec\.|\.stories\.|\.qa\.|/config/|/types/|/data/|/_registry/|/__tests__/|/docs/|/adrs/|^scripts/|/scripts/|/i18n/locales/|-definitions\.|-schema|-constants|enterprise-id\.service\.ts)'; then
            echo 0
            return
        fi

        # Component: .tsx files inside components/ or ui/
        if echo "$file" | grep -qE '\.(tsx)$' && echo "$file" | grep -qE '(/components/|/ui/)'; then
            echo 500
            return
        fi

        # Hook: files starting with use*.ts
        if echo "$file" | grep -qE '/use[A-Z][^/]*\.ts$'; then
            echo 500
            return
        fi

        # Service: *.service.ts files
        if echo "$file" | grep -qE '\.service\.ts$'; then
            echo 500
            return
        fi

        # API Route: route.ts inside api/
        if echo "$file" | grep -qE '/api/.*route\.ts$'; then
            echo 300
            return
        fi

        # General .ts/.tsx (catch-all)
        echo 500
    }

    # Human-readable type name for error messages
    get_file_type() {
        local file="$1"
        if echo "$file" | grep -qE '\.(tsx)$' && echo "$file" | grep -qE '(/components/|/ui/)'; then
            echo "Component"
            return
        fi
        if echo "$file" | grep -qE '/use[A-Z][^/]*\.ts$'; then
            echo "Hook"
            return
        fi
        if echo "$file" | grep -qE '\.service\.ts$'; then
            echo "Service"
            return
        fi
        if echo "$file" | grep -qE '/api/.*route\.ts$'; then
            echo "API Route"
            return
        fi
        echo "General"
    }

    while IFS= read -r file; do
        if [[ -z "$file" ]]; then
            continue
        fi

        MAX_LINES=$(get_max_lines "$file")

        # 0 = exempt
        if [[ "$MAX_LINES" -eq 0 ]]; then
            continue
        fi

        if [[ -f "$file" ]]; then
            LINE_COUNT=$(wc -l < "$file" | tr -d ' ')
            if [[ "$LINE_COUNT" -gt "$MAX_LINES" ]]; then
                FILE_TYPE=$(get_file_type "$file")
                OVERSIZED_FILES="${OVERSIZED_FILES}  ❌ ${file} (${LINE_COUNT}/${MAX_LINES} lines — ${FILE_TYPE})\n"
            fi
        fi
    done <<< "$TS_FILES"

    if [[ -n "$OVERSIZED_FILES" ]]; then
        echo ""
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo -e "${RED}  🚫 COMMIT BLOCKED - File Size Exceeds Type-Specific Limit${NC}"
        echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo -e "${YELLOW}Limits: Component 500 | Hook 500 | Service 500 | API 300 | General 500${NC}"
        echo -e "$OVERSIZED_FILES"
        echo ""
        echo -e "${YELLOW}Fix: Split into smaller, focused modules (Single Responsibility).${NC}"
        echo -e "${YELLOW}Exempt: config/, types/, data/, tests, definitions, schemas, i18n${NC}"
        echo ""
        exit 1
    fi

    echo -e "${GREEN}  ✅ File sizes OK${NC}"
fi

