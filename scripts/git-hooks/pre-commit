        INDEX_COVERAGE_TARGETS="$STAGED_TS"
    fi

    if [[ -n "$INDEX_COVERAGE_TARGETS" ]]; then
        echo -e "${YELLOW}🔍 Checking Firestore index coverage...${NC}"

        INDEX_COVERAGE_OUTPUT=$(node "$INDEX_COVERAGE_SCRIPT" $INDEX_COVERAGE_TARGETS 2>&1)
        INDEX_COVERAGE_EXIT=$?

        if [[ $INDEX_COVERAGE_EXIT -ne 0 ]]; then
            echo "$INDEX_COVERAGE_OUTPUT"
            echo ""
            echo -e "${RED}✖ CHECK 3.15 failed — fix the missing composite indexes above.${NC}"
            echo -e "${YELLOW}  Tip: run 'npm run firestore:indexes:audit' for a full scan report.${NC}"
            exit 1
        fi

        if [[ -n "$INDEX_COVERAGE_OUTPUT" ]]; then
            echo "$INDEX_COVERAGE_OUTPUT"
        fi
    fi
fi

